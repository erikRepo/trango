// TrangoPlayer main window shell.
//
// Top bar in its full visual form per STYLE.md's design tokens (wordmark,
// segmented control, toggle, ghost buttons) — pixel reference is
// sketch/design_reference.dc.html#1c, extended with a segmented control for
// the Video/Audio source and a "Sentence by sentence" toggle (TODO.md Vaihe
// 25, not in the mock). The two controls are independent: `select-mode`
// (handled in Rust, crates/app/src/main.rs) drives
// playback-state::PlayerState::set_mode() and mirrors the result back into
// `playback-mode`, which also drives the bottom `HintBar`'s mode-specific
// content; `select-media-source` drives PlayerState::set_media_source() and
// mirrors into `media-source`, which switches the video area between the
// mpv frame and the Audio source's placeholder panel. Both source buttons
// also call `pause-playback` first (video_player::VideoPlayer::pause()),
// since there's one shared mpv instance/loaded file underneath both
// panels — see `media-ready`'s doc comment.

import { LineEdit, ListView, ScrollView } from "std-widgets.slint";

/// Color tokens from STYLE.md's "Design Tokens" section, shared across the
/// top bar components below.
global Palette {
    out property <color> window-bg: #1c1d22;
    out property <color> panel-bg: #202127;
    out property <color> border: #3a3c45;
    out property <color> accent: #3b6fd6;
    out property <color> primary-text: #e7e8ec;
    out property <color> muted-text: #8a8d99;
    out property <color> ghost-text: #b4b7c0;
    out property <color> segmented-bg: #2a2c33;
    out property <color> translation-text: #7fa6f0;
    out property <color> modal-bg: #22232a;
    out property <color> chip-muted: #4a4d59;
    out property <color> error-text: #e5484d;
}

/// Subtitle generation status for the Open Subtitles dialog's "Generate
/// subtitles" flow (`TODO.md` Vaihe 20, SPEC.md's `subtitleGenerationStatus`).
/// Driven from Rust (`crates/app/src/subtitle_generation.rs`) as
/// `AppWindow::subtitle-generation-status`.
export enum SubtitleGenerationStatus {
    Idle,
    Generating,
    Done,
    Error,
}

/// State of the "Analyze all sentences" batch loop (`TODO.md` Vaihe 24,
/// part 4/6) — mirrors `SubtitleGenerationStatus`'s Idle/running/Done/Error
/// shape. Set from Rust by `crates/app/src/word_analysis.rs`.
export enum WordAnalysisBatchStatus {
    Idle,
    Running,
    Done,
    Error,
}

/// Mirrors `playback_state::PlaybackMode` for the top bar's "Sentence by
/// sentence" toggle (on = `SentenceBySentence`, off = `Normal` — "Normal" is
/// never shown in the UI). Named `PlaybackModeUi` rather than `PlaybackMode`
/// to avoid colliding with the Rust type of the same name that
/// `crates/app/src/main.rs` imports alongside this generated module.
export enum PlaybackModeUi {
    Normal,
    SentenceBySentence,
}

/// Mirrors `playback_state::MediaSource` (`TODO.md` Vaihe 25) for the top
/// bar's Video/Audio segmented control and the video/placeholder-panel
/// switch below. Named `MediaSourceUi` for the same reason `PlaybackModeUi`
/// is: avoids colliding with the Rust type `crates/app/src/main.rs` imports
/// alongside this generated module.
export enum MediaSourceUi {
    Video,
    Audio,
}

/// One pill in the top bar's Video / Audio source segmented control; filled
/// with the accent color while `active`, muted otherwise.
component SegmentButton {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-radius: 5px;
        background: root.active ? Palette.accent : transparent;

        layout := HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 6px;
            padding-bottom: 6px;

            Text {
                text: root.label;
                color: root.active ? white : Palette.muted-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// Pill-shaped on/off switch used by the current-sentence card's
/// "Secondary subtitle" toggle: accent-filled track with a white knob when
/// `on`, muted track with the knob on the left otherwise.
component ToggleSwitch {
    in property <bool> on;
    callback toggled;

    width: 34px;
    height: 18px;

    Rectangle {
        border-radius: self.height / 2;
        background: root.on ? Palette.accent : Palette.segmented-bg;
        border-width: 1px;
        border-color: Palette.border;

        Rectangle {
            width: 14px;
            height: 14px;
            border-radius: self.height / 2;
            background: white;
            y: (parent.height - self.height) / 2;
            x: root.on ? parent.width - self.width - 2px : 2px;

            animate x { duration: 120ms; easing: ease-out; }
        }

        TouchArea {
            clicked => { root.toggled(); }
        }
    }
}

/// A bordered, no-fill "Open" / "Subtitles…" top bar button.
/// "Open" is wired to the Open dialog (Vaihe 18, generalized to audio in
/// Vaihe 28); "Subtitles…" to the Open Subtitles dialog (Vaihe 19) — both
/// are `FileListDialog` instances, see below.
component GhostButton {
    in property <string> label;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-width: 1px;
        border-radius: 6px;
        border-color: Palette.border;

        layout := HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 7px;
            padding-bottom: 7px;

            Text {
                text: root.label;
                color: Palette.ghost-text;
                font-family: "JetBrains Mono";
                font-size: 12px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// Small square icon-only button — used for the top bar's Settings gear.
/// Fixed-size box rather than GhostButton's auto-sized `layout.min-width`,
/// since that width is measured from its "JetBrains Mono" label glyph
/// metrics — a glyph rendered from a different (fallback) font, as "⚙"
/// would be, mismeasures and clips (see RecordButton's doc comment below
/// for the same issue hit there).
component IconButton {
    in property <string> glyph;
    callback clicked;

    width: 32px;
    height: 32px;

    Rectangle {
        border-width: 1px;
        border-radius: 6px;
        border-color: Palette.border;

        Text {
            text: root.glyph;
            color: Palette.ghost-text;
            font-family: "Inter";
            font-size: 15px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// Rec/stop control for the Audio source's placeholder panel (`TODO.md`
/// Vaihe 27): filled red with a "Stop" label while `recording`, bordered
/// with a "Rec" label otherwise. Wired to the same `toggle-audio-capture`
/// callback as Ctrl+Space, so either one starts/stops the same capture.
/// Plain text labels only, deliberately no "●"/"■" glyph prefix — mixing a
/// non-ASCII glyph into "JetBrains Mono" text measured for an
/// auto-sized (`layout.min-width`) button clipped the label's last
/// character, since the glyph's actual rendered (fallback-font) width
/// didn't match what was measured for layout.
component RecordButton {
    in property <bool> recording;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-width: 1px;
        border-radius: 6px;
        border-color: root.recording ? Palette.error-text : Palette.border;
        background: root.recording ? Palette.error-text : transparent;

        layout := HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 7px;
            padding-bottom: 7px;

            Text {
                text: root.recording ? "Stop" : "Rec";
                color: root.recording ? white : Palette.error-text;
                font-family: "JetBrains Mono";
                font-size: 12px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// The right-hand sentence panel's top card: "Sentence N / M" (uppercase,
/// mono, muted) left / "Secondary subtitle" label + toggle switch right,
/// above the current cue's original-language text, a divider, and (while
/// `show-translation` is on) the translation text in accent-tinted blue.
/// `sentence-label`/`sentence-text`/`has-sentence`/`translation-text` are
/// set from Rust: `main.rs` after loading a subtitle file, and
/// `video_player.rs`'s scrub bar poll (while in `SentenceBySentence` mode,
/// synced from mpv's `time-pos`) — see `crates/app/src/sentence_card.rs`.
/// `show-translation` is wired directly to `main.rs`'s `toggle-translation`
/// callback (see `wire_player_state`), independent of cue changes. The
/// sentence-list card underneath it arrives in a later TODO.md step.
component CurrentSentenceCard {
    in property <string> sentence-label;
    in property <string> sentence-text;
    in property <bool> has-sentence;
    in property <string> translation-text;
    in property <bool> show-translation;
    callback toggle-translation;

    /// Fixed height for the original-language sentence's scroll area —
    /// roughly 4 lines of the 24px/600 Inter sentence text. Without this,
    /// a long cue's wrapped text has no bounded height to lay out against:
    /// when the sentence panel column runs out of vertical room (a small
    /// window, or `SentenceListCard` below claiming its `vertical-stretch:
    /// 1` share), the card gets squeezed shorter than the text's wrapped
    /// height needs, silently clipping the bottom line(s) instead of
    /// showing or scrolling to them. Fixed height, same fix as
    /// `translation-height` below: long sentences scroll inside this box
    /// instead of being cut off.
    property <length> sentence-height: 150px;

    /// Fixed height for the translation line's scroll area — roughly 3
    /// lines of the 18px/500 Inter translation text. Fixed rather than
    /// sized to content so the card (and, below it, the sentence list's
    /// available height) doesn't visibly grow/shrink every time the
    /// current cue's translation changes length; longer translations
    /// scroll inside this box instead.
    property <length> translation-height: 84px;

    Rectangle {
        border-width: 1px;
        border-radius: 8px;
        border-color: Palette.border;
        background: Palette.panel-bg;

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                alignment: space-between;
                cross-axis-alignment: center;

                Text {
                    text: root.sentence-label;
                    color: Palette.muted-text;
                    font-family: "JetBrains Mono";
                    font-size: 10px;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: 8px;
                    cross-axis-alignment: center;

                    Text {
                        text: "Secondary subtitle";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 12px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }

                    ToggleSwitch {
                        on: root.show-translation;
                        toggled => { root.toggle-translation(); }
                    }
                }
            }

            ScrollView {
                height: root.sentence-height;

                Text {
                    text: root.sentence-text;
                    color: root.has-sentence ? Palette.primary-text : Palette.muted-text;
                    font-family: "Inter";
                    font-size: 24px;
                    font-weight: 600;
                    wrap: word-wrap;
                    width: parent.width;
                }
            }

            Rectangle {
                height: 1px;
                background: Palette.border;
            }

            if root.show-translation : ScrollView {
                height: root.translation-height;

                Text {
                    text: root.translation-text;
                    color: Palette.translation-text;
                    font-family: "Inter";
                    font-size: 18px;
                    font-weight: 500;
                    wrap: word-wrap;
                    width: parent.width;
                }
            }
        }
    }
}

/// One row in the sentence list: `"index · text"`, plus whether it's the
/// currently focused cue (highlighted with an accent-tinted pill).
struct SentenceListRow {
    label: string,
    is-current: bool,
}

/// The right-hand sentence panel's scrollable "all cues" list, underneath
/// `CurrentSentenceCard`. `rows`/`current-index` are set from Rust
/// (`crates/app/src/sentence_list.rs`) whenever the loaded cues or the
/// current cue change. Clicking a row emits `row-clicked` with that row's
/// index, which `main.rs` wires to the same `playback-state::jump_to_cue`
/// navigation used by arrow-key navigation — see SPEC.md's "Sentence list"
/// interaction spec.
component SentenceListCard inherits Rectangle {
    in property <[SentenceListRow]> rows: [];
    in property <int> current-index: -1;
    callback row-clicked(int);

    /// Fixed row height, matched by `row-y`/`bring-into-view` below so the
    /// scroll-into-view math doesn't need to measure text layout.
    property <length> row-height: 32px;

    border-width: 1px;
    border-radius: 8px;
    border-color: Palette.border;
    background: Palette.panel-bg;

    VerticalLayout {
        padding: 12px;
        spacing: 4px;

        Text {
            text: "Sentence list";
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 10px;
            font-weight: 600;
        }

        list := ListView {
            for row[index] in root.rows : Rectangle {
                height: root.row-height;
                border-radius: 6px;
                background: row.is-current ? Palette.accent.with-alpha(0.22) : transparent;

                Text {
                    text: row.label;
                    color: row.is-current ? Palette.primary-text : Palette.muted-text;
                    font-family: "Inter";
                    font-size: 13px;
                    font-weight: 500;
                    overflow: elide;
                    x: 10px;
                    width: parent.width - 20px;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.row-clicked(index); }
                }
            }
        }
    }

    /// The current row's y position within `list`'s scrolled viewport —
    /// negative/beyond `visible-height` means it's currently out of view.
    pure function row-y(index: int) -> length {
        return list.viewport-y + index * root.row-height;
    }

    /// Scrolls `list` just enough to bring row `index` fully into view,
    /// without otherwise disturbing the current scroll position.
    function bring-into-view(index: int) {
        if (row-y(index) < 0) {
            list.viewport-y += 0 - row-y(index);
        }
        if (row-y(index) + root.row-height > list.visible-height) {
            list.viewport-y -= row-y(index) + root.row-height - list.visible-height;
        }
    }

    changed current-index => {
        if (root.current-index < 0 || root.current-index >= root.rows.length) {
            return;
        }
        root.bring-into-view(root.current-index);
    }
}

/// One row in a `FileListDialog` listing: either a navigable row (the
/// "‥ Up" row or a subfolder — `is-navigable`, no `size-label`, never
/// `is-selected`; clicking it navigates the dialog to a different folder)
/// or a selectable file (`is-selected` driving the accent-tinted
/// background/chip color). Set from Rust in
/// `crates/app/src/open_media_dialog.rs` (video or audio files, with folder
/// navigation) and `crates/app/src/open_subtitles_dialog.rs` (translation
/// `.srt` files, flat — see `FileListDialog`'s doc comment on why the same
/// row shape covers both).
struct FileListRow {
    name: string,
    size-label: string,
    is-selected: bool,
    is-navigable: bool,
}

/// A generic file-picker modal: header (`title` + "✕"), a scrollable list
/// of `rows` under `folder-label`, and a footer with "Cancel" + a filled
/// `confirm-label` button. Used for the Open dialog (`TODO.md` Vaihe 18 —
/// pixel reference `sketch/design_reference.dc.html#2a`, left mock,
/// extended here with in-dialog folder navigation not shown in that static
/// mock; generalized to list audio recordings too in Vaihe 28) and the Open
/// Subtitles dialog's translation-link picker (Vaihe 19, see
/// `OpenSubtitlesDialog` below) — both are "browse a folder's files and
/// pick one", just scoped to different extensions and (for the Open
/// dialog only) with subfolder navigation.
/// `folder-label`/`rows`/`selected-index` are set from Rust when the
/// dialog opens and again whenever a navigable row changes the listed
/// folder. Clicking a row emits `row-clicked` with its index — the Rust
/// side decides whether that navigates (an `Up`/`Folder` row) or selects
/// (a file row); the backdrop, header "✕", and footer "Cancel" all emit
/// `cancel`; footer `confirm-label` emits `confirm` (a no-op while nothing
/// is selected).
component FileListDialog {
    in property <string> title;
    in property <string> confirm-label;
    in property <string> folder-label;
    in property <[FileListRow]> rows: [];
    in property <int> selected-index: -1;
    callback row-clicked(int);
    callback cancel();
    callback confirm();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            // Clicking the dimmed backdrop cancels, same as the header's
            // close button and footer's Cancel button.
            clicked => { root.cancel(); }
        }

        Rectangle {
            width: 640px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's cancel handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: root.title;
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.cancel(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 16px;
                    spacing: 6px;

                    Text {
                        text: root.folder-label;
                        color: Palette.muted-text;
                        font-family: "JetBrains Mono";
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 0.8px;
                    }

                    if root.rows.length == 0 : Text {
                        text: "This folder is empty.";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 13px;
                    }

                    ListView {
                        for row[index] in root.rows : Rectangle {
                            height: 44px;
                            border-radius: 7px;
                            background: row.is-selected ? Palette.accent.with-alpha(0.22) : transparent;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 10px;
                                cross-axis-alignment: center;

                                if !row.is-navigable : Rectangle {
                                    width: 28px;
                                    height: 20px;
                                    border-radius: 3px;
                                    background: row.is-selected ? Palette.accent : Palette.chip-muted;
                                }

                                VerticalLayout {
                                    alignment: center;

                                    Text {
                                        text: row.name;
                                        color: row.is-selected ? Palette.primary-text : Palette.ghost-text;
                                        font-family: "Inter";
                                        font-size: 13px;
                                        font-weight: row.is-navigable ? 600 : 500;
                                        overflow: elide;
                                    }

                                    if row.size-label != "" : Text {
                                        text: row.size-label;
                                        color: Palette.muted-text;
                                        font-family: "JetBrains Mono";
                                        font-size: 11px;
                                    }
                                }
                            }

                            TouchArea {
                                clicked => { root.row-clicked(index); }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        spacing: 10px;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Cancel";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.cancel(); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;
                            opacity: root.selected-index >= 0 ? 1.0 : 0.5;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: root.confirm-label;
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    if (root.selected-index >= 0) {
                                        root.confirm();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// One word's analysis in the Ctrl+A popup below: the word as it appears
/// in the sentence, its translation, and a pronunciation guide. Mirrors
/// `word_analysis::WordEntry` (`crates/word-analysis/src/entry.rs`), set
/// from Rust by `crates/app/src/word_analysis.rs`. `word`/`pronunciation`
/// always describe the whole word as written/spoken — for a word made of
/// multiple morphemes (Hebrew's attached prefix particles, e.g. לסרטים =
/// ל "to" + סרטים "movies"), `parts-label` carries a pre-formatted
/// breakdown of `translation` (e.g. "ל = to · סרטים = movies"), empty for
/// words with nothing to break down.
struct WordAnalysisRow {
    word: string,
    translation: string,
    pronunciation: string,
    parts-label: string,
}

/// State of the Ctrl+A word-analysis popup (`TODO.md` Vaihe 24, part 5/6)
/// — `Idle` before it's ever been opened, `Loading` while a background
/// Ollama call for an uncached sentence is in flight, `Done` once
/// `word-analysis-rows` has content to show, `Error` (with
/// `word-analysis-error-message`) if no model/subtitle is available or
/// the Ollama call failed.
export enum WordAnalysisStatus {
    Idle,
    Loading,
    Done,
    Error,
}

/// Ctrl+A's word-by-word analysis popup for the sentence currently shown
/// in the current-sentence card: header ("Word analysis" + "✕"), a
/// scrollable list of `word · translation · pronunciation` rows (or a
/// loading/error message in place of the list), footer "Close". Opened by
/// `AppWindow`'s `show-word-analysis` (wired in `main.rs`'s
/// `wire_word_analysis_popup` to Ctrl+A, see `nav-focus`'s `key-pressed`
/// below); closed by the backdrop, header "✕", or footer "Close", all
/// emitting `close`.
component WordAnalysisPopup {
    in property <WordAnalysisStatus> status: WordAnalysisStatus.Idle;
    in property <[WordAnalysisRow]> rows: [];
    in property <string> error-message: "";
    callback close();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            clicked => { root.close(); }
        }

        Rectangle {
            width: 480px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's close handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: "Word analysis";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.close(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 16px;
                    spacing: 6px;

                    if root.status == WordAnalysisStatus.Loading : Text {
                        text: "Analyzing…";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 13px;
                    }

                    if root.status == WordAnalysisStatus.Error : Text {
                        text: root.error-message;
                        color: Palette.error-text;
                        font-family: "Inter";
                        font-size: 13px;
                        wrap: word-wrap;
                    }

                    if root.status == WordAnalysisStatus.Done : ListView {
                        for row in root.rows : Rectangle {
                            height: row.parts-label == "" ? 56px : 74px;
                            border-radius: 7px;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 10px;
                                cross-axis-alignment: center;

                                VerticalLayout {
                                    alignment: center;

                                    Text {
                                        text: row.word;
                                        color: Palette.primary-text;
                                        font-family: "Inter";
                                        font-size: 15px;
                                        font-weight: 600;
                                    }

                                    Text {
                                        text: row.pronunciation;
                                        color: Palette.muted-text;
                                        font-family: "JetBrains Mono";
                                        font-size: 11px;
                                    }
                                }

                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    spacing: 2px;

                                    Text {
                                        text: row.translation;
                                        color: Palette.translation-text;
                                        font-family: "Inter";
                                        font-size: 14px;
                                        font-weight: 500;
                                        horizontal-alignment: right;
                                    }

                                    if row.parts-label != "" : Text {
                                        text: row.parts-label;
                                        color: Palette.muted-text;
                                        font-family: "Inter";
                                        font-size: 11px;
                                        horizontal-alignment: right;
                                        wrap: word-wrap;
                                    }
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Close";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.close(); }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// One row in the Ctrl+W word-timing popup: a word plus its
/// `[start, end)` span within the source file, from
/// `subtitle::WordTiming` (`crates/subtitle/src/word_timing.rs`), set
/// from Rust by `crates/app/src/word_timing_ui.rs`. `start-label`/
/// `end-label` are pre-formatted ("M:SS.mmm") in Rust, same as
/// `WordAnalysisRow.parts-label` above; `start-seconds`/`end-seconds`
/// are the raw values a row click hands back via `WordTimingPopup.play`
/// so `main.rs` can play exactly that span without a separate lookup.
struct WordTimingRow {
    word: string,
    start-label: string,
    end-label: string,
    start-seconds: float,
    end-seconds: float,
}

/// State of the Ctrl+W word-timing popup (`TODO.md` Vaihe 32) — mirrors
/// `WordAnalysisStatus` exactly: `Idle` before it's ever been opened,
/// `Loading` while `whisper-cli` is segmenting the current sentence's
/// audio, `Done` once `word-timing-rows` has content, `Error` (with
/// `word-timing-error-message`) if no whisper model/media is available,
/// no sentence is in focus, or the segmentation itself failed.
export enum WordTimingStatus {
    Idle,
    Loading,
    Done,
    Error,
}

/// Ctrl+W's per-word audio-timing popup for the sentence currently shown
/// in the current-sentence card: header ("Word timing" + "✕"), a
/// scrollable list of `word · start – end` rows (or a loading/error
/// message in place of the list), footer "Close". Clicking a row plays
/// back exactly that word's audio span (`play`, wired in `main.rs` to
/// `video_player::VideoPlayer::toggle_play_span`) — the main way this
/// popup is actually used, letting the DTW timing be heard rather than
/// just read as numbers. Opened by `AppWindow`'s `show-word-timing`
/// (wired in `main.rs`'s `wire_word_timing_popup` to Ctrl+W, see
/// `nav-focus`'s `key-pressed` below); closed by the backdrop, header
/// "✕", or footer "Close", all emitting `close`.
component WordTimingPopup {
    in property <WordTimingStatus> status: WordTimingStatus.Idle;
    in property <[WordTimingRow]> rows: [];
    in property <string> error-message: "";
    callback close();
    callback play(float, float);

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            clicked => { root.close(); }
        }

        Rectangle {
            width: 480px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's close handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: "Word timing";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.close(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 16px;
                    spacing: 6px;

                    if root.status == WordTimingStatus.Loading : Text {
                        text: "Segmenting…";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 13px;
                    }

                    if root.status == WordTimingStatus.Error : Text {
                        text: root.error-message;
                        color: Palette.error-text;
                        font-family: "Inter";
                        font-size: 13px;
                        wrap: word-wrap;
                    }

                    if root.status == WordTimingStatus.Done : ListView {
                        for row in root.rows : Rectangle {
                            height: 44px;
                            border-radius: 7px;

                            TouchArea {
                                clicked => { root.play(row.start-seconds, row.end-seconds); }
                            }

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                alignment: space-between;
                                cross-axis-alignment: center;

                                Text {
                                    text: row.word;
                                    color: Palette.primary-text;
                                    font-family: "Inter";
                                    font-size: 15px;
                                    font-weight: 600;
                                }

                                Text {
                                    text: row.start-label + " – " + row.end-label;
                                    color: Palette.muted-text;
                                    font-family: "JetBrains Mono";
                                    font-size: 12px;
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Close";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.close(); }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// One editable "label / value" row in `SettingsDialog` below — a small-
/// caps mono label above a `LineEdit`, matching the section-header style
/// used elsewhere in the dialogs (e.g. OpenSubtitlesDialog's "Original
/// subtitle").
component SettingsEditRow {
    in property <string> label;
    in property <string> value;
    in property <string> placeholder;
    callback edited(string);

    VerticalLayout {
        spacing: 4px;

        Text {
            text: root.label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 0.8px;
        }

        LineEdit {
            text: root.value;
            placeholder-text: root.placeholder;
            font-size: 13px;
            edited(text) => { root.edited(text); }
        }
    }
}

/// Settings screen (`TODO.md`-adjacent — not in the original list, added
/// on request): shows and edits every `config::TrangoConfig` field
/// (docs/src/usage/settings.md) in one place. Whisper/Ollama model
/// selection reopens the same picker dialogs reached from the Open
/// Subtitles dialog (`select-whisper-model`/`select-ollama-model`, wired
/// to the same top-level `select-whisper-model-requested`/
/// `select-ollama-model-requested` callbacks) rather than duplicating
/// folder-browsing/Ollama-listing UI here; every other field is a plain
/// `LineEdit` that saves immediately on Enter/focus-out, same as the Open
/// Subtitles dialog's target-language field — no separate "Save" action.
component SettingsDialog {
    in property <string> config-path;
    in property <string> video-folder;
    in property <bool> whisper-model-selected: false;
    in property <string> whisper-model-name;
    in property <bool> ollama-model-selected: false;
    in property <string> ollama-model-name;
    in property <string> ollama-target-language;
    in property <string> audio-monitor-source;
    in property <string> audio-recording-folder;
    in property <bool> audio-recording-folder-exists: true;
    in property <bool> niqud-model-selected: false;
    in property <string> niqud-model-name;
    in property <bool> niqud-model-needs-restart: false;
    callback set-video-folder(string);
    callback select-whisper-model();
    callback select-ollama-model();
    callback set-ollama-target-language(string);
    callback set-audio-monitor-source(string);
    callback set-audio-recording-folder(string);
    callback select-niqud-model();
    callback close();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            clicked => { root.close(); }
        }

        Rectangle {
            width: 560px;
            height: 560px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's close handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: "Settings";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.close(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 20px;
                    spacing: 14px;

                    SettingsEditRow {
                        label: "VIDEO FOLDER";
                        value: root.video-folder;
                        placeholder: "not set yet — picked from the last video you opened";
                        edited(text) => { root.set-video-folder(text); }
                    }

                    VerticalLayout {
                        spacing: 4px;

                        Text {
                            text: "WHISPER MODEL";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.whisper-model-selected
                                        ? root.whisper-model-name + " (change)"
                                        : "select a whisper model…";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 13px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-whisper-model(); }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 4px;

                        Text {
                            text: "OLLAMA MODEL";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.ollama-model-selected
                                        ? root.ollama-model-name + " (change)"
                                        : "select an Ollama model…";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 13px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-ollama-model(); }
                            }
                        }
                    }

                    SettingsEditRow {
                        label: "WORD ANALYSIS TARGET LANGUAGE";
                        value: root.ollama-target-language;
                        placeholder: "e.g. English";
                        edited(text) => { root.set-ollama-target-language(text); }
                    }

                    SettingsEditRow {
                        label: "AUDIO MONITOR SOURCE (OVERRIDE)";
                        value: root.audio-monitor-source;
                        placeholder: "auto-detected via pactl";
                        edited(text) => { root.set-audio-monitor-source(text); }
                    }

                    SettingsEditRow {
                        label: "AUDIO RECORDING FOLDER";
                        value: root.audio-recording-folder;
                        placeholder: "current working directory";
                        edited(text) => { root.set-audio-recording-folder(text); }
                    }

                    if !root.audio-recording-folder-exists : Text {
                        text: "This folder doesn't exist yet — recording will fail until it does.";
                        color: Palette.error-text;
                        font-family: "Inter";
                        font-size: 12px;
                        wrap: word-wrap;
                    }

                    VerticalLayout {
                        spacing: 4px;

                        Text {
                            text: "HEBREW NIQUD MODEL (.ONNX)";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.niqud-model-selected
                                        ? root.niqud-model-name + " (change)"
                                        : "not set — Hebrew pronunciation falls back to Ollama's guess";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 13px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-niqud-model(); }
                            }
                        }

                        if root.niqud-model-needs-restart : Text {
                            text: "Restart TrangoPlayer to use this model — the pick is saved, but Hebrew word analysis keeps using whatever was loaded at startup until then.";
                            color: Palette.muted-text;
                            font-family: "Inter";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: Palette.border;
                    }

                    Text {
                        text: "Config file: " + root.config-path;
                        color: Palette.muted-text;
                        font-family: "JetBrains Mono";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Close";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.close(); }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// One monospace keyboard-shortcut entry in `HintBar` below — factored out
/// since every entry shares the same styling and `HintBar` now switches a
/// varying subset of them on/off per mode.
component HintLabel {
    in property <string> text;

    Text {
        text: root.text;
        color: Palette.muted-text;
        font-family: "JetBrains Mono";
        font-size: 11px;
        font-weight: 500;
        vertical-alignment: center;
    }
}

/// Bottom hint bar, shown in both modes (see `AppWindow`, where it's
/// instantiated unconditionally), listing whichever keyboard shortcuts
/// actually do something in the mode `sentence-mode-active` names.
/// Right/Left (next/previous sentence) only work in `SentenceBySentence`
/// mode — `AppWindow`'s `key-pressed` handler rejects them outright
/// otherwise (see its own doc comment) — so they're hidden here in `Normal`
/// mode; Space always works, but its hint label differs (repeat-the-current-
/// line vs. plain play/pause) depending on whether there's a cue to bound it
/// to. Right/Left/Space drive `next-cue`/`previous-cue`/`repeat-cue`, wired
/// to `playback-state` navigation and mpv seeking in
/// `crates/app/src/main.rs` and `video_player.rs`. Ctrl+T/Ctrl+A/Ctrl+W
/// (`toggle-translation`/`show-word-analysis`/`show-word-timing`,
/// `TODO.md` Vaihe 24/32) work unconditionally in either mode, so
/// they're always shown.
component HintBar {
    in property <bool> sentence-mode-active: true;

    height: 34px;

    Rectangle {
        background: Palette.window-bg;
        border-width: 1px;
        border-color: Palette.border;

        HorizontalLayout {
            alignment: center;
            spacing: 24px;

            if root.sentence-mode-active : HintLabel {
                text: "← previous sentence";
            }

            if root.sentence-mode-active : HintLabel {
                text: "space · repeat sentence";
            }

            if !root.sentence-mode-active : HintLabel {
                text: "space · play/pause";
            }

            if root.sentence-mode-active : HintLabel {
                text: "→ next sentence";
            }

            HintLabel {
                text: "ctrl+t · toggle secondary subtitle";
            }

            HintLabel {
                text: "ctrl+a · word analysis";
            }

            HintLabel {
                text: "ctrl+w · word timing";
            }
        }
    }
}

/// Time / progress control below the video frame: current time (mono,
/// muted) — 4px track with accent-filled progress and a white circular
/// thumb — total time (mono, muted). `current-time-label`/`duration-label`
/// and `progress` (0.0–1.0) are set from Rust, which polls mpv's
/// `time-pos`/`duration` properties (see `video_player.rs`). Clicking or
/// dragging the track fires `seek-requested` with the pointer's fraction
/// (0.0–1.0) across the track's width — forwarded to `AppWindow`'s own
/// `seek-requested` callback, wired in `main.rs` to
/// `video_player::VideoPlayer::seek_to_fraction`. The fraction isn't clamped
/// here: a drag beyond the track's own edges reports values outside
/// 0.0–1.0, which `seek_to_fraction` clamps on the Rust side instead (see
/// its doc comment), rather than duplicating that clamp in both places.
component ScrubBar {
    in property <string> current-time-label;
    in property <string> duration-label;
    in property <float> progress: 0.0;
    callback seek-requested(float);

    height: 32px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 10px;
        cross-axis-alignment: center;

        Text {
            text: root.current-time-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }

        track := Rectangle {
            height: 4px;
            border-radius: 2px;
            background: Palette.border;

            Rectangle {
                x: 0px;
                width: parent.width * root.progress;
                height: parent.height;
                border-radius: 2px;
                background: Palette.accent;
            }

            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: white;
                x: parent.width * root.progress - self.width / 2;
                y: (parent.height - self.height) / 2;
            }

            // Taller than the 4px track itself so the draggable hit target
            // isn't a hairline to aim for — centered on the visible track.
            touch := TouchArea {
                height: 24px;
                y: (parent.height - self.height) / 2;

                clicked => {
                    root.seek-requested(touch.mouse-x / touch.width);
                }
                moved => {
                    if touch.pressed {
                        root.seek-requested(touch.mouse-x / touch.width);
                    }
                }
            }
        }

        Text {
            text: root.duration-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
}

/// Playback-speed control, shown directly below `ScrubBar` and always
/// visible regardless of mode — useful for language learners who want to
/// slow a video down without leaving Normal or Sentence-by-sentence mode.
/// Maximum is normal speed (right edge, "1.0x"); dragging left only slows
/// the video down, it never speeds it up. `current-speed`/
/// `current-speed-label` are set from Rust
/// (`crates/app/src/main.rs`'s `wire_speed_slider`, via
/// `video_player.rs`'s `VideoPlayer::set_speed`), the fraction-to-speed
/// mapping and label formatting done by `playback_state::speed_from_fraction`/
/// `format_speed_label` so it's covered by plain Rust unit tests instead of
/// Slint. `min-speed`/`max-speed` mirror `playback_state::{MIN_SPEED,MAX_SPEED}`
/// (0.5-1.0) — Slint can't import Rust constants directly, so they must be
/// kept in sync by hand. Clicking or dragging the track fires
/// `speed-requested` with the pointer's fraction (0.0-1.0) across the
/// track's width, same contract as `ScrubBar`'s `seek-requested`.
component SpeedSlider {
    in property <float> current-speed: 1.0;
    in property <string> current-speed-label: "1.00x";
    callback speed-requested(float);

    property <float> min-speed: 0.5;
    property <float> max-speed: 1.0;
    property <float> progress: (root.current-speed - root.min-speed) / (root.max-speed - root.min-speed);

    height: 44px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 10px;
        cross-axis-alignment: center;

        Text {
            text: "Speed";
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }

        track := Rectangle {
            height: 4px;
            border-radius: 2px;
            background: Palette.border;

            Rectangle {
                x: 0px;
                width: parent.width * root.progress;
                height: parent.height;
                border-radius: 2px;
                background: Palette.accent;
            }

            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: white;
                x: parent.width * root.progress - self.width / 2;
                y: (parent.height - self.height) / 2;
            }

            Text {
                text: "0.5x";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 10px;
                font-weight: 500;
                x: 0px;
                y: 12px;
            }

            Text {
                text: "0.75x";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 10px;
                font-weight: 500;
                x: parent.width / 2 - self.width / 2;
                y: 12px;
            }

            Text {
                text: "1.0x";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 10px;
                font-weight: 500;
                x: parent.width - self.width;
                y: 12px;
            }

            // Taller than the 4px track itself, matching ScrubBar's own
            // touch target sizing — a hairline is hard to aim for.
            touch := TouchArea {
                height: 24px;
                y: (parent.height - self.height) / 2;

                clicked => {
                    root.speed-requested(touch.mouse-x / touch.width);
                }
                moved => {
                    if touch.pressed {
                        root.speed-requested(touch.mouse-x / touch.width);
                    }
                }
            }
        }

        Text {
            text: root.current-speed-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
            horizontal-alignment: right;
            width: 44px;
        }
    }
}

/// A subtitle file already linked to the video: small accent chip + name +
/// muted "linked" tag. Used by `OpenSubtitlesDialog` for both the
/// original-language and translation sections once a file is set — per
/// SPEC.md, both get "the same visual treatment" once linked.
component LinkedFileRow {
    in property <string> file-name;

    Rectangle {
        border-radius: 7px;
        background: Palette.accent.with-alpha(0.14);

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 10px;
            padding-bottom: 10px;
            spacing: 10px;
            cross-axis-alignment: center;

            Rectangle {
                width: 24px;
                height: 18px;
                border-radius: 3px;
                background: Palette.accent;
            }

            Text {
                text: root.file-name;
                color: Palette.primary-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 500;
                horizontal-stretch: 1;
                overflow: elide;
            }

            Text {
                text: "linked";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
            }
        }
    }
}

/// An unlinked-file placeholder row: muted border, `label` text — used by
/// `OpenSubtitlesDialog`'s original section (no subtitle found) and
/// translation section (nothing linked yet). Pixel reference
/// `sketch/design_reference.dc.html#2a`'s dashed empty state; Slint has no
/// dashed-border support, so this approximates it with a solid muted
/// border instead.
component EmptyFileRow {
    in property <string> label;

    Rectangle {
        border-width: 1.5px;
        border-radius: 7px;
        border-color: Palette.chip-muted;

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 12px;
            padding-bottom: 12px;

            Text {
                text: root.label;
                color: Palette.muted-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }
    }
}

/// The Open Subtitles dialog (`TODO.md` Vaihe 19): a modal scoped to the
/// currently open video — pixel reference
/// `sketch/design_reference.dc.html#2a`, right mock. `title`/
/// `original-linked`/`original-name`/`translation-linked`/`translation-name`
/// are set from Rust (`crates/app/src/open_subtitles_dialog.rs`) when the
/// top bar's "Subtitles…" button is clicked. The original-language
/// section shows a `LinkedFileRow` if found on disk, else an empty-state
/// row whose text and "Generate subtitles"/"Generating…"/"Try again"
/// button reflect `generation-status` (`TODO.md` Vaihe 20) — clicking it
/// emits `generate-subtitles`, wired in `main.rs` to
/// `subtitle_generation::generate`. The "Secondary subtitle"
/// section always shows either state too, plus a small "link…" text below
/// it — clicking either opens `main.rs`'s link-translation file picker
/// (`link-translation`), since real OS drag-and-drop isn't available (see
/// `AppWindow`'s `link-translation-requested` doc comment). Backdrop,
/// header "✕", and footer "Cancel" all emit `cancel`; footer "Done" emits
/// `confirm` — both just close the modal, see `AppWindow`'s
/// `cancel-open-subtitles-dialog`/`confirm-open-subtitles-dialog` doc
/// comment for why nothing more needs to happen on "Done".
component OpenSubtitlesDialog {
    in property <string> title;
    in property <bool> original-linked;
    in property <string> original-name;
    in property <SubtitleGenerationStatus> generation-status: SubtitleGenerationStatus.Idle;
    in property <string> generation-error-message: "";
    in property <bool> model-selected: false;
    in property <string> model-name: "";
    in property <bool> translation-linked;
    in property <string> translation-name;
    in property <bool> ollama-model-selected: false;
    in property <string> ollama-model-name: "";
    in property <string> ollama-target-language: "";
    in property <WordAnalysisBatchStatus> word-analysis-batch-status: WordAnalysisBatchStatus.Idle;
    in property <int> word-analysis-batch-progress-current: 0;
    in property <int> word-analysis-batch-progress-total: 0;
    in property <string> word-analysis-batch-error-message: "";
    callback generate-subtitles();
    callback select-model();
    callback select-ollama-model();
    callback set-ollama-target-language(string);
    callback analyze-all-sentences();
    callback link-translation();
    callback cancel();
    callback confirm();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            clicked => { root.cancel(); }
        }

        Rectangle {
            width: 640px;
            height: 560px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's cancel handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: root.title;
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.cancel(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 20px;
                    spacing: 16px;

                    VerticalLayout {
                        spacing: 8px;

                        Text {
                            text: "Original subtitle";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        if root.original-linked : LinkedFileRow {
                            file-name: root.original-name;
                        }

                        if !root.original-linked : Rectangle {
                            border-width: 1.5px;
                            border-radius: 7px;
                            border-color: Palette.chip-muted;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 10px;
                                padding-bottom: 10px;
                                alignment: space-between;
                                cross-axis-alignment: center;

                                Text {
                                    text: root.generation-status == SubtitleGenerationStatus.Generating
                                        ? "Generating…"
                                        : root.generation-status == SubtitleGenerationStatus.Error
                                            ? "Generation failed"
                                            : "No subtitle file found";
                                    color: root.generation-status == SubtitleGenerationStatus.Error
                                        ? Palette.error-text
                                        : Palette.muted-text;
                                    font-family: "Inter";
                                    font-size: 13px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    border-radius: 6px;
                                    background: Palette.accent;
                                    opacity: root.generation-status == SubtitleGenerationStatus.Generating || !root.model-selected ? 0.55 : 1.0;

                                    HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        padding-top: 8px;
                                        padding-bottom: 8px;

                                        Text {
                                            text: root.generation-status == SubtitleGenerationStatus.Generating
                                                ? "Generating…"
                                                : root.generation-status == SubtitleGenerationStatus.Error
                                                    ? "Try again"
                                                    : "Generate subtitles";
                                            color: white;
                                            font-family: "Inter";
                                            font-size: 12px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                        }
                                    }

                                    TouchArea {
                                        enabled: root.generation-status != SubtitleGenerationStatus.Generating && root.model-selected;
                                        clicked => { root.generate-subtitles(); }
                                    }
                                }
                            }
                        }

                        if !root.original-linked : Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.model-selected
                                        ? "whisper model: " + root.model-name + " (change)"
                                        : "select a whisper model to enable generation…";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 11px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-model(); }
                            }
                        }

                        if root.generation-status == SubtitleGenerationStatus.Error && root.generation-error-message != "" : Text {
                            text: root.generation-error-message;
                            color: Palette.error-text;
                            font-family: "Inter";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;

                        Text {
                            text: "Secondary subtitle";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        if root.translation-linked : LinkedFileRow {
                            file-name: root.translation-name;
                        }

                        if !root.translation-linked : EmptyFileRow {
                            label: "No secondary subtitle linked";
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.translation-linked
                                        ? "change linked secondary subtitle file…"
                                        : "click to link a secondary subtitle .srt file";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 11px;
                                    font-weight: 500;
                                }
                            }

                            TouchArea {
                                clicked => { root.link-translation(); }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;

                        Text {
                            text: "Word analysis (Ollama)";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.ollama-model-selected
                                        ? "Ollama model: " + root.ollama-model-name + " (change)"
                                        : "select an Ollama model for word analysis…";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 11px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-ollama-model(); }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            cross-axis-alignment: center;

                            Text {
                                text: "Target language:";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 11px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }

                            LineEdit {
                                horizontal-stretch: 1;
                                text: root.ollama-target-language;
                                placeholder-text: "e.g. English";
                                font-size: 12px;
                                edited(text) => { root.set-ollama-target-language(text); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;
                            opacity: root.word-analysis-batch-status == WordAnalysisBatchStatus.Running || !root.ollama-model-selected ? 0.55 : 1.0;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: root.word-analysis-batch-status == WordAnalysisBatchStatus.Running
                                        ? "Analyzing " + root.word-analysis-batch-progress-current + " / " + root.word-analysis-batch-progress-total + "…"
                                        : root.word-analysis-batch-status == WordAnalysisBatchStatus.Error
                                            ? "Try again"
                                            : root.word-analysis-batch-status == WordAnalysisBatchStatus.Done
                                                ? "Analyzed all sentences"
                                                : "Analyze all sentences";
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                enabled: root.word-analysis-batch-status != WordAnalysisBatchStatus.Running && root.ollama-model-selected;
                                clicked => { root.analyze-all-sentences(); }
                            }
                        }

                        if root.word-analysis-batch-status == WordAnalysisBatchStatus.Error && root.word-analysis-batch-error-message != "" : Text {
                            text: root.word-analysis-batch-error-message;
                            color: Palette.error-text;
                            font-family: "Inter";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: Palette.border;
                    }

                    Text {
                        text: "Generating uses on-device speech recognition — no upload.";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 12px;
                        font-weight: 500;
                        wrap: word-wrap;
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        spacing: 10px;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Cancel";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.cancel(); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Done";
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.confirm(); }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    in property <string> version;
    // Mirrors playback_state::PlaybackMode — kept in sync from Rust by
    // main.rs's wire_player_state, which also derives HintBar's/nav-focus's
    // narrower sentence-mode-active bool from this. Hardcoded to Normal here
    // as this component's own default; wire_player_state overwrites it with
    // PlayerState::new()'s real default (SentenceBySentence) immediately.
    in property <PlaybackModeUi> playback-mode: PlaybackModeUi.Normal;
    // Derived from playback-mode for nav-focus's key-pressed guard and
    // HintBar. `out` rather than private so tests can assert on it directly
    // instead of only on the coarser playback-mode.
    out property <bool> sentence-mode-active: root.playback-mode == PlaybackModeUi.SentenceBySentence;
    // Mirrors playback_state::MediaSource — kept in sync from Rust by
    // main.rs's wire_player_state, which also drives nav-focus's Ctrl+Space
    // guard and the video-area/placeholder-panel switch below. Hardcoded to
    // Video here as this component's own default, matching
    // MediaSource::default().
    in property <MediaSourceUi> media-source: MediaSourceUi.Video;
    // Invoked by the top bar's Video/Audio segmented control with the
    // clicked segment's target source — wired in main.rs to
    // playback_state::PlayerState::set_media_source().
    callback select-media-source(MediaSourceUi);
    // Invoked alongside select-media-source, before it, by the same
    // segmented control clicks — wired in main.rs to
    // video_player::VideoPlayer::pause(). A source switch only changes
    // which panel is visible (there's still one shared mpv instance/loaded
    // file underneath, see loaded-media-source below), so without this,
    // whatever was playing in the panel being hidden would keep running
    // silently behind the other one.
    callback pause-playback();
    // Which source (Video or Audio) the currently loaded file in mpv
    // actually is — set in main.rs's open_selected_media alongside
    // video-loaded, independently of media-source above (the visible
    // panel). Used below to only show playback controls/the video
    // underlay in the panel matching what's actually loaded, rather than,
    // e.g., a loaded video's ScrubBar bleeding into the Audio panel just
    // because *some* file happens to be loaded.
    in property <MediaSourceUi> loaded-media-source: MediaSourceUi.Video;
    // Whether crates/app/src/video_player.rs has an mpv OpenGL render
    // context underlay active. While true, the video area below is left
    // fully transparent so that underlay (drawn straight into the window's
    // backbuffer before this scene, via Window::set_rendering_notifier) is
    // visible through it; opaque window-bg is only needed as a placeholder
    // when no video is loaded yet.
    in property <bool> video-loaded: false;
    // Whether the currently loaded file (video-loaded) actually is the kind
    // of media the visible panel (media-source) shows — false, e.g., right
    // after switching from Video to Audio with a video still loaded from
    // before. Gates the mpv underlay/ScrubBar/SpeedSlider/Audio placeholder
    // below so a stale load from the other source doesn't bleed into this
    // one.
    out property <bool> media-ready: root.video-loaded && root.loaded-media-source == root.media-source;
    // The video frame Rectangle's resolved on-screen geometry, relative to
    // this window — read by `video_player.rs`'s `render_frame` each frame so
    // the mpv underlay it draws can be confined to exactly this box (via an
    // offscreen FBO + blit) rather than the whole window. Summed from the
    // named ancestors' own `x`/`y` (each relative to *its* parent) since
    // Slint has no built-in "position relative to window" accessor; safe
    // here because every ancestor above `body-row` sits at (0, 0) with no
    // padding of its own, so `body-row.x`/`.y` already are window-relative.
    out property <length> video-frame-x: body-row.x + video-column.x + video-frame.x;
    out property <length> video-frame-y: body-row.y + video-column.y + video-frame.y;
    out property <length> video-frame-width: video-frame.width;
    out property <length> video-frame-height: video-frame.height;
    // Scrub bar state, polled from mpv's `time-pos`/`duration` properties in
    // video_player.rs and formatted via playback_state::format_time.
    in property <string> current-time-label: "00:00";
    in property <string> duration-label: "00:00";
    in property <float> scrub-progress: 0.0;
    // Playback-speed slider state, mirrored from mpv's `speed` property by
    // main.rs's wire_speed_slider whenever the SpeedSlider below is
    // dragged/clicked — see its own doc comment.
    in property <float> current-playback-speed: 1.0;
    in property <string> current-playback-speed-label: "1.00x";
    callback speed-requested(float);
    // Current-sentence card state, mirrored from playback_state::PlayerState
    // by crates/app/src/sentence_card.rs — see CurrentSentenceCard above.
    in property <string> sentence-label: "Sentence – / –";
    in property <string> sentence-text: "No sentence loaded.";
    in property <bool> has-current-sentence: false;
    in property <string> translation-text: "";
    // Whether the current-sentence card's translation line is shown,
    // mirrored from playback_state::PlayerState.show_translation by
    // main.rs's wire_player_state — flipped by the toggle-translation
    // callback below, off by default.
    in property <bool> show-translation: false;
    // Sentence list state, mirrored from playback_state::PlayerState by
    // crates/app/src/sentence_list.rs — see SentenceListCard above.
    in property <[SentenceListRow]> sentence-list-rows: [];
    in property <int> sentence-list-current-index: -1;
    // Invoked by the top bar's "Sentence by sentence" toggle with the
    // resulting target mode — wired in main.rs to
    // playback_state::PlayerState::set_mode().
    callback select-mode(PlaybackModeUi);
    // Invoked by the current-sentence card's Translation toggle switch —
    // wired in main.rs's wire_player_state to
    // playback_state::PlayerState::toggle_translation().
    callback toggle-translation();
    // Sentence-by-sentence navigation, invoked by `nav-focus`'s key-pressed
    // handler below for Right/Left (SentenceBySentence mode only) and
    // Space (both modes, repeat-cue only) respectively — see
    // `crates/app/src/main.rs` for how they drive `playback-state` and mpv.
    callback next-cue();
    callback previous-cue();
    callback repeat-cue();
    // Sentence list row click, invoked by SentenceListCard with the clicked
    // row's index — wired in main.rs to playback_state::jump_to_cue, the
    // same navigation call arrow keys drive.
    callback jump-to-cue(int);
    // Scrub bar click/drag, invoked by ScrubBar with the pointer's fraction
    // (0.0-1.0, not pre-clamped) across the track — wired in main.rs to
    // video_player::VideoPlayer::seek_to_fraction. Unlike jump-to-cue above,
    // this only relocates the playhead; it never changes play/pause state.
    callback seek-requested(float);
    // Open dialog state (TODO.md Vaihe 18, generalized to audio in Vaihe
    // 28), set from Rust by crates/app/src/open_media_dialog.rs — see
    // FileListDialog above. Shared by the Video and Audio sources' "Open…"
    // button: open-media-dialog-title and the listed rows depend on
    // whichever source is active when the button is clicked
    // (main.rs's wire_open_media_dialog).
    in property <bool> is-open-media-dialog-open: false;
    in property <string> open-media-dialog-title: "Open video file";
    in property <string> open-media-folder-label: "";
    in property <[FileListRow]> open-media-rows: [];
    in property <int> open-media-selected-index: -1;
    // Invoked by the top bar's "Open…" GhostButton; wired in main.rs's
    // wire_open_media_dialog to list the default folder's video or audio
    // files (depending on media-source) and open the dialog.
    callback open-media-dialog-requested();
    // Invoked by the dialog's backdrop click / "✕" / "Cancel" — closes it.
    callback cancel-open-media-dialog();
    // Invoked by a dialog row click, with that row's index — marks it
    // selected.
    callback select-open-media-row(int);
    // Invoked by the dialog's "Open" button — loads the selected file.
    callback confirm-open-media();
    // Open Subtitles dialog state (TODO.md Vaihe 19), set from Rust by
    // crates/app/src/open_subtitles_dialog.rs — see OpenSubtitlesDialog
    // below.
    in property <bool> is-open-subtitles-dialog-open: false;
    in property <string> open-subtitles-title: "";
    in property <bool> open-subtitles-original-linked: false;
    in property <string> open-subtitles-original-name: "";
    in property <bool> open-subtitles-translation-linked: false;
    in property <string> open-subtitles-translation-name: "";
    // Invoked by the top bar's "Subtitles…" GhostButton.
    callback open-subtitles-dialog-requested();
    // Invoked by the dialog's backdrop click / "✕" / "Cancel" / "Done" —
    // all just close it: the original subtitle (if found) is already
    // loaded by the time the dialog opens, and a linked translation is
    // applied immediately when picked (see link-translation-requested
    // below), so there's nothing left to apply on "Done".
    callback cancel-open-subtitles-dialog();
    callback confirm-open-subtitles-dialog();
    // Invoked by the original-language section's "Generate subtitles"
    // button (TODO.md Vaihe 20/21.5) — wired in main.rs's
    // wire_open_subtitles_dialog to subtitle::WhisperCliGenerator, run on a
    // background thread (real transcription can take minutes) via
    // subtitle_generation::spawn_generate. Its result is mirrored back into
    // subtitle-generation-status/-error-message below and, on success, the
    // original row via open_subtitles_dialog::mark_original_linked.
    callback generate-subtitles-requested();
    // Idle/Generating/Done/Error for the flow above, set from Rust by
    // crates/app/src/subtitle_generation.rs. Reset to Idle each time the
    // Open Subtitles dialog opens (open_subtitles_dialog::open_dialog).
    in property <SubtitleGenerationStatus> subtitle-generation-status: SubtitleGenerationStatus.Idle;
    // Human-readable failure reason for the Error state above (e.g.
    // "whisper-cli not found (looked for ...) — install whisper.cpp..."),
    // shown in place of a generic "Generation failed" message. Empty
    // outside the Error state; reset alongside subtitle-generation-status.
    in property <string> subtitle-generation-error-message: "";
    // Internal signal, not tied to any UI element: invoked from Rust
    // (main.rs's generate-subtitles-requested handler) once a background
    // whisper-cli run finishes successfully, carrying the new subtitle's
    // path. Exists because the handler's `slint::invoke_from_event_loop`
    // callback (dispatched from a background thread, so it may only
    // capture `Send` data — a `Weak<AppWindow>` plus this path string) has
    // no way to reach the `Rc<RefCell<PlayerState>>`/`Rc<RefCell<CurrentMedia>>`
    // that loading the subtitle into the player needs; invoking this
    // callback hands off to a handler set up once on the UI thread
    // (`wire_open_subtitles_dialog`) that does have them.
    callback subtitle-generated(string);
    // Invoked by the translation section's "click to link…" text. Opens
    // the link-translation file picker below rather than accepting an
    // OS-level file drop like the design mock: Slint 1.17.1's winit
    // backend doesn't relay external file drops to `DropArea`, only
    // in-app `DragArea` sources, of which this dialog has none.
    callback link-translation-requested();
    // The translation-link file picker (a FileListDialog scoped to the
    // video's folder's .srt files), set from Rust by
    // crates/app/src/open_subtitles_dialog.rs.
    in property <bool> is-link-translation-dialog-open: false;
    in property <string> link-translation-folder-label: "";
    in property <[FileListRow]> link-translation-rows: [];
    in property <int> link-translation-selected-index: -1;
    callback select-link-translation-row(int);
    callback cancel-link-translation-dialog();
    callback confirm-link-translation();
    // Whisper model selection (TODO.md Vaihe 21.6): which ggml/gguf model
    // "Generate subtitles" runs `subtitle::WhisperCliGenerator` against.
    // Set from Rust by crates/app/src/model_picker.rs; persisted across
    // restarts by crates/app/src/config.rs.
    in property <bool> whisper-model-selected: false;
    in property <string> whisper-model-name: "";
    // Invoked by the Open Subtitles dialog's model row. Opens the model
    // picker (a FileListDialog scoped to .bin/.gguf files, same chrome as
    // the Open dialog), starting from an autodiscovered or
    // previously-picked folder (model_picker::default_start_folder).
    callback select-whisper-model-requested();
    in property <bool> is-model-picker-dialog-open: false;
    in property <string> model-picker-folder-label: "";
    in property <[FileListRow]> model-picker-rows: [];
    in property <int> model-picker-selected-index: -1;
    callback select-model-picker-row(int);
    callback cancel-model-picker-dialog();
    callback confirm-model-picker-dialog();
    // Hebrew niqud ONNX model selection: which model
    // niqud::OnnxNiqudClient loads to correct Hebrew word-analysis
    // pronunciation. Set from Rust by
    // crates/app/src/niqud_model_picker.rs; persisted across restarts by
    // crates/app/src/config.rs. Only reachable from the Settings dialog
    // (no Open Subtitles dialog row, unlike whisper/Ollama models).
    in property <bool> niqud-model-selected: false;
    in property <string> niqud-model-name: "";
    // Set from Rust once a pick is confirmed — niqud_client_from_config
    // only runs once at startup, so a pick made here doesn't take effect
    // until trango is restarted; the Settings dialog shows a hint once
    // this is true (see SettingsDialog's niqud-model-needs-restart row).
    in property <bool> niqud-model-needs-restart: false;
    callback select-niqud-model-requested();
    in property <bool> is-niqud-model-picker-dialog-open: false;
    in property <string> niqud-model-picker-folder-label: "";
    in property <[FileListRow]> niqud-model-picker-rows: [];
    in property <int> niqud-model-picker-selected-index: -1;
    callback select-niqud-model-picker-row(int);
    callback cancel-niqud-model-picker-dialog();
    callback confirm-niqud-model-picker-dialog();
    // Ollama model selection (TODO.md Vaihe 24): which locally installed
    // Ollama model the Ctrl+A popup and "Analyze all sentences" batch loop
    // run word-by-word sentence analysis against. Set from Rust by
    // crates/app/src/ollama_model_picker.rs; persisted across restarts by
    // crates/app/src/config.rs, the same way whisper-model-selected is.
    in property <bool> ollama-model-selected: false;
    in property <string> ollama-model-name: "";
    // Invoked by the Open Subtitles dialog's Ollama model row. Opens the
    // model picker (a FileListDialog listing models Ollama reports, no
    // folder navigation — see ollama_model_picker.rs's module doc for why
    // listing runs on a background thread unlike the whisper model
    // picker's synchronous filesystem listing).
    callback select-ollama-model-requested();
    in property <bool> is-ollama-model-picker-open: false;
    in property <bool> ollama-model-picker-loading: false;
    in property <string> ollama-model-picker-error: "";
    in property <[FileListRow]> ollama-model-picker-rows: [];
    in property <int> ollama-model-picker-selected-index: -1;
    callback select-ollama-model-picker-row(int);
    callback cancel-ollama-model-picker-dialog();
    callback confirm-ollama-model-picker-dialog();
    // Target language for word analysis (TODO.md Vaihe 24.1): what
    // translations/pronunciations are produced in. Free-text field (the
    // Open Subtitles dialog's LineEdit) rather than a fixed list, since
    // any language name is valid input. Set from Rust by
    // crates/app/src/main.rs's wire_ollama_target_language; persisted
    // across restarts by crates/app/src/config.rs, the same way the
    // Ollama model is.
    in property <string> ollama-target-language: "";
    callback set-ollama-target-language(string);
    // Ctrl+A word-analysis popup (TODO.md Vaihe 24, part 5/6): analyzes the
    // sentence currently shown in the current-sentence card. Set from Rust
    // by crates/app/src/word_analysis.rs's wire_word_analysis_popup.
    callback show-word-analysis();
    // Ctrl+Space (TODO.md Vaihe 26) and the Audio panel's RecordButton
    // (Vaihe 27): starts/stops system-audio capture in the Audio source —
    // gated to that source in nav-focus's key-pressed handler below, since
    // capture has no meaning while a video is loaded. Set from Rust by
    // crates/app/src/system_audio_capture.rs. A failure (e.g. missing
    // pactl/ffmpeg) is surfaced via audio-capture-error-message below,
    // rather than only logged, so a broken setup doesn't look like
    // Ctrl+Space/the button silently did nothing.
    callback toggle-audio-capture();
    // Mirrors the most recent start/stop attempt's outcome: "" on success,
    // an explanatory message on failure (e.g. "pactl not found..." or a
    // failed rename). Cleared again on the next successful attempt. Shown
    // in the Audio source's placeholder below.
    in property <string> audio-capture-error-message: "";
    // Whether a system-audio capture is currently in progress (TODO.md
    // Vaihe 27) — drives RecordButton's Rec/Stop state and locks the
    // filename field below against edits while true. Set from Rust by
    // crates/app/src/system_audio_capture.rs alongside every successful
    // start/stop.
    in property <bool> is-audio-recording: false;
    // The current (or, once stopped, most recently finished) recording's
    // filename, e.g. "2026-07-17_18-42-05.wav" — "" before any recording
    // has been made this session. Set from Rust on every successful
    // start/rename; editable via the filename LineEdit below once
    // is-audio-recording is false.
    in property <string> audio-recording-filename: "";
    // Fired (Enter key) when the filename field is edited after a
    // recording has stopped; renames the file on disk to match. Ignored by
    // Rust while is-audio-recording is true.
    callback rename-audio-recording-file(string);
    // The folder a new Audio-source recording will be written to
    // (`system_audio_capture::default_recording_folder`), shown in the
    // Audio panel so it's clear where Ctrl+Space/the Rec button will save
    // before a recording is even started, and kept in sync if it's
    // changed via the Settings dialog below. Set from Rust by
    // crates/app/src/system_audio_capture.rs.
    in property <string> audio-recording-folder-label: "";
    callback close-word-analysis-popup();
    in property <bool> is-word-analysis-popup-open: false;
    in property <WordAnalysisStatus> word-analysis-status: WordAnalysisStatus.Idle;
    in property <[WordAnalysisRow]> word-analysis-rows: [];
    in property <string> word-analysis-error-message: "";
    // Ctrl+W word-timing popup (TODO.md Vaihe 32): segments the sentence
    // currently shown in the current-sentence card into per-word audio
    // timing via whisper-cli DTW. Set from Rust by
    // crates/app/src/main.rs's wire_word_timing_popup /
    // crates/app/src/word_timing_ui.rs.
    callback show-word-timing();
    callback close-word-timing-popup();
    callback play-word-timing(float, float);
    in property <bool> is-word-timing-popup-open: false;
    in property <WordTimingStatus> word-timing-status: WordTimingStatus.Idle;
    in property <[WordTimingRow]> word-timing-rows: [];
    in property <string> word-timing-error-message: "";
    // "Analyze all sentences" batch loop (TODO.md Vaihe 24, part 4/6): runs
    // word-by-word analysis for every cue not already in the subtitle's
    // cache file. Set from Rust by crates/app/src/word_analysis.rs.
    callback analyze-all-requested();
    in property <WordAnalysisBatchStatus> word-analysis-batch-status: WordAnalysisBatchStatus.Idle;
    in property <int> word-analysis-batch-progress-current: 0;
    in property <int> word-analysis-batch-progress-total: 0;
    in property <string> word-analysis-batch-error-message: "";

    // Settings screen (top bar's gear icon): shows most of
    // config::TrangoConfig's remembered settings (docs/src/usage/settings.md)
    // in one place — set from Rust by crates/app/src/settings_dialog.rs.
    // Most fields mirror properties already kept in sync elsewhere
    // (whisper-model-name etc.) rather than duplicating that state; only
    // fields with no other UI get their own settings-* property below.
    callback settings-dialog-requested();
    in property <bool> is-settings-dialog-open: false;
    in property <string> settings-config-path: "";
    in property <string> settings-video-folder: "";
    // audio-monitor-source previously had *no* UI at all (config.toml had
    // to be hand-edited — see settings.md); audio-recording-folder mirrors
    // the same config field the Audio panel's audio-recording-folder-label
    // above is derived from. Both save immediately on edit, the same way
    // the Open Subtitles dialog's target-language field does
    // (set-ollama-target-language), rather than needing a separate "Save".
    in property <string> settings-audio-monitor-source: "";
    in property <string> settings-audio-recording-folder: "";
    in property <bool> settings-audio-recording-folder-exists: true;
    callback set-settings-video-folder(string);
    callback set-settings-audio-monitor-source(string);
    callback set-settings-audio-recording-folder(string);
    callback close-settings-dialog();

    title: "TrangoPlayer v" + version;
    // `preferred-width`/`-height`, not `width`/`height`: per Slint's
    // `Window` docs, binding `width`/`height` directly makes the window a
    // *fixed* size (`min-width`==`max-width` at the window-manager level) —
    // the OS-level frame could still be dragged/maximized bigger (its
    // decorations aren't Slint's concern), but Slint's own content stayed
    // clamped to this fixed size in the corner of that bigger frame,
    // leaving the rest of the window an unpainted gap. `preferred-width`/
    // `-height` only set the *initial* size and leave the window freely
    // resizable, letting the content column below (bound to `width`/
    // `height: 100%`) actually grow and shrink with it. 660px tall
    // comfortably fits the sentence panel's default content
    // (current-sentence card + at least a few sentence-list rows) plus the
    // bottom `HintBar` without either being cramped at startup.
    preferred-width: 960px;
    preferred-height: 660px;
    forward-focus: nav-focus;

    // Restores keyboard focus to `nav-focus` once the Open Subtitles dialog
    // closes. That dialog's target-language `LineEdit` (see
    // OpenSubtitlesDialog below, the "Word analysis (Ollama)" section) can
    // grab keyboard focus while the dialog is open; since the dialog is a
    // conditionally-instantiated child (`if is-open-subtitles-dialog-open`
    // below), closing it destroys the focused `LineEdit` outright, leaving
    // no item focused. Without this, nav-focus's `key-pressed` (Space,
    // Right/Left) never fires again until the user happens to click
    // somewhere else — reported as "Space does nothing" after generating
    // subtitles and then running word analysis, both driven from this
    // dialog.
    changed is-open-subtitles-dialog-open => {
        if (!root.is-open-subtitles-dialog-open) {
            nav-focus.focus();
        }
    }

    nav-focus := FocusScope {
        key-pressed(event) => {
            if (event.modifiers.control && (event.text == "t" || event.text == "T")) {
                // Translation visibility is purely visual and independent
                // of playback mode (see SPEC.md), so Ctrl+T is handled
                // before the sentence-mode-active guard below, unlike
                // Right/Left which only make sense in SentenceBySentence
                // mode.
                root.toggle-translation();
                accept
            } else if (event.modifiers.control && (event.text == "a" || event.text == "A")) {
                // Word analysis targets whatever sentence the
                // current-sentence card is showing right now, same as
                // Ctrl+T above — not mode-gated for the same reason.
                root.show-word-analysis();
                accept
            } else if (event.modifiers.control && (event.text == "w" || event.text == "W")) {
                // Word timing, same target/reasoning as Ctrl+A above —
                // whatever sentence the current-sentence card is showing.
                root.show-word-timing();
                accept
            } else if (event.modifiers.control && event.text == " ") {
                // Starts/stops system-audio capture (TODO.md Vaihe 26,
                // Audio source only) — checked before the plain-Space
                // branch below, since Ctrl held or not still reports the
                // same " " text.
                if (root.media-source == MediaSourceUi.Audio) {
                    root.toggle-audio-capture();
                }
                accept
            } else if (event.text == " ") {
                // Space (play/pause) works in both modes — see
                // repeat-cue's doc comment for why it's the same callback
                // as Sentence-by-sentence's "replay current cue": the Rust
                // handler falls back to a plain toggle when there's no
                // current cue to bound playback to (Normal mode, or no
                // subtitle linked yet).
                root.repeat-cue();
                accept
            } else if (!root.sentence-mode-active) {
                reject
            } else if (event.text == Key.RightArrow) {
                root.next-cue();
                accept
            } else if (event.text == Key.LeftArrow) {
                root.previous-cue();
                accept
            } else {
                reject
            }
        }

        VerticalLayout {
            // `nav-focus` (a `FocusScope`, not a `Layout`) doesn't stretch an
            // arbitrary single child to fill itself the way a `Layout`
            // stretches its own children — without an explicit `width`/
            // `height` here, this column just takes its natural content
            // size (which is why `AppWindow`'s `width`/`height` above had to
            // be hand-tuned to match it) and stays that size regardless of
            // how big the actual window grows, leaving dead space around it
            // instead of the video/sentence-panel area growing into a
            // resized or maximized window.
            width: 100%;
            height: 100%;

            Rectangle {
                height: 52px;
                background: Palette.panel-bg;
                border-width: 1px;
                border-color: Palette.border;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    alignment: space-between;
                    cross-axis-alignment: center;

                    HorizontalLayout {
                        spacing: 10px;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: Palette.accent;
                            y: (parent.height - self.height) / 2;
                        }

                        Text {
                            text: "TrangoPlayer";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    HorizontalLayout {
                        // Wider than the 8px used for buttons within a
                        // group — visually separates the Video/Audio
                        // segmented control from the unrelated Sentence-by-
                        // sentence toggle next to it.
                        spacing: 24px;

                        // Video/Audio source, independent of the Sentence-
                        // by-sentence toggle next to it — separate control
                        // group since the two choices are orthogonal.
                        Rectangle {
                            background: Palette.segmented-bg;
                            border-radius: 7px;

                            HorizontalLayout {
                                padding: 3px;
                                spacing: 2px;

                                SegmentButton {
                                    label: "Video";
                                    active: root.media-source == MediaSourceUi.Video;
                                    clicked => {
                                        root.pause-playback();
                                        root.select-media-source(MediaSourceUi.Video);
                                    }
                                }

                                SegmentButton {
                                    label: "Audio";
                                    active: root.media-source == MediaSourceUi.Audio;
                                    clicked => {
                                        root.pause-playback();
                                        root.select-media-source(MediaSourceUi.Audio);
                                    }
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            cross-axis-alignment: center;

                            Text {
                                text: "Sentence by sentence";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 13px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            ToggleSwitch {
                                on: root.sentence-mode-active;
                                toggled => {
                                    root.select-mode(root.sentence-mode-active
                                        ? PlaybackModeUi.Normal
                                        : PlaybackModeUi.SentenceBySentence);
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        GhostButton {
                            label: "Open";
                            clicked => { root.open-media-dialog-requested(); }
                        }

                        GhostButton {
                            label: "Subtitles…";
                            clicked => { root.open-subtitles-dialog-requested(); }
                        }

                        IconButton {
                            glyph: "⚙";
                            clicked => { root.settings-dialog-requested(); }
                        }
                    }
                }
            }

            body-row := HorizontalLayout {
                padding: 16px;
                spacing: 16px;

                video-column := VerticalLayout {
                    spacing: 8px;

                    video-frame := Rectangle {
                        // Video frame area, filling the remaining column height.
                        // Transparent while a video is loaded and matches the
                        // visible panel so the mpv underlay shows through (see
                        // `media-ready` above); otherwise filled with the
                        // window background color as a placeholder — also
                        // covering a loaded video's picture while the Audio
                        // panel is showing, since that overlay is itself
                        // transparent. Its resolved on-screen geometry is
                        // exposed below (`video-frame-x`/-y/-width/-height) so
                        // `video_player.rs` can confine the mpv underlay to
                        // exactly this box instead of the whole window — see
                        // `render_frame`'s doc comment. Kept unconditionally
                        // instantiated (rather than swapped out via `if`) even
                        // in the Audio source, so those geometry accessors
                        // keep resolving; the Audio placeholder below is just
                        // an overlay child instead.
                        background: root.media-ready ? transparent : Palette.window-bg;

                        if root.media-source == MediaSourceUi.Audio : VerticalLayout {
                            // Rec/stop control, filename display/rename
                            // (TODO.md Vaihe 27), always available so a new
                            // recording can start at any time. Once a
                            // recording or opened audio file is loaded
                            // (media-ready), the placeholder text below
                            // gives way to the ScrubBar/SpeedSlider below
                            // this Rectangle, which play it back the same
                            // way they do a video (TODO.md Vaihe 28).
                            alignment: center;
                            spacing: 10px;

                            if !root.media-ready : Text {
                                text: "Audio source — no recording loaded";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 13px;
                                horizontal-alignment: center;
                            }

                            if root.audio-recording-folder-label != "" : Text {
                                text: "Saving to: " + root.audio-recording-folder-label;
                                color: Palette.muted-text;
                                font-family: "JetBrains Mono";
                                font-size: 11px;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }

                            HorizontalLayout {
                                alignment: center;
                                spacing: 8px;

                                RecordButton {
                                    recording: root.is-audio-recording;
                                    clicked => { root.toggle-audio-capture(); }
                                }

                                if root.audio-recording-filename != "" : LineEdit {
                                    width: 220px;
                                    text: root.audio-recording-filename;
                                    enabled: !root.is-audio-recording;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    accepted(text) => { root.rename-audio-recording-file(text); }
                                }
                            }

                            if root.audio-capture-error-message != "" : Text {
                                text: root.audio-capture-error-message;
                                color: Palette.error-text;
                                font-family: "Inter";
                                font-size: 12px;
                                horizontal-alignment: center;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Shown in the Video source unconditionally (even
                    // before anything's loaded, as an idle 0:00 state), and
                    // in the Audio source once a matching recording or
                    // opened audio file is loaded (media-ready, TODO.md
                    // Vaihe 28) — there's nothing to scrub/speed-control
                    // before that, and a video loaded from before a source
                    // switch shouldn't show its scrub bar here either.
                    if root.media-source != MediaSourceUi.Audio || root.media-ready : ScrubBar {
                        current-time-label: root.current-time-label;
                        duration-label: root.duration-label;
                        progress: root.scrub-progress;
                        seek-requested(fraction) => { root.seek-requested(fraction); }
                    }

                    if root.media-source != MediaSourceUi.Audio || root.media-ready : SpeedSlider {
                        current-speed: root.current-playback-speed;
                        current-speed-label: root.current-playback-speed-label;
                        speed-requested(fraction) => { root.speed-requested(fraction); }
                    }
                }

                VerticalLayout {
                    width: 320px;
                    spacing: 12px;

                    CurrentSentenceCard {
                        vertical-stretch: 0;
                        sentence-label: root.sentence-label;
                        sentence-text: root.sentence-text;
                        has-sentence: root.has-current-sentence;
                        translation-text: root.translation-text;
                        show-translation: root.show-translation;
                        toggle-translation => { root.toggle-translation(); }
                    }

                    SentenceListCard {
                        vertical-stretch: 1;
                        rows: root.sentence-list-rows;
                        current-index: root.sentence-list-current-index;
                        row-clicked(index) => { root.jump-to-cue(index); }
                    }
                }
            }

            HintBar {
                sentence-mode-active: root.sentence-mode-active;
            }
        }

        if root.is-open-media-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: root.open-media-dialog-title;
            confirm-label: "Open";
            folder-label: root.open-media-folder-label;
            rows: root.open-media-rows;
            selected-index: root.open-media-selected-index;
            row-clicked(index) => { root.select-open-media-row(index); }
            cancel => { root.cancel-open-media-dialog(); }
            confirm => { root.confirm-open-media(); }
        }

        if root.is-open-subtitles-dialog-open : OpenSubtitlesDialog {
            width: parent.width;
            height: parent.height;
            title: root.open-subtitles-title;
            original-linked: root.open-subtitles-original-linked;
            original-name: root.open-subtitles-original-name;
            generation-status: root.subtitle-generation-status;
            generation-error-message: root.subtitle-generation-error-message;
            model-selected: root.whisper-model-selected;
            model-name: root.whisper-model-name;
            translation-linked: root.open-subtitles-translation-linked;
            translation-name: root.open-subtitles-translation-name;
            ollama-model-selected: root.ollama-model-selected;
            ollama-model-name: root.ollama-model-name;
            ollama-target-language: root.ollama-target-language;
            word-analysis-batch-status: root.word-analysis-batch-status;
            word-analysis-batch-progress-current: root.word-analysis-batch-progress-current;
            word-analysis-batch-progress-total: root.word-analysis-batch-progress-total;
            word-analysis-batch-error-message: root.word-analysis-batch-error-message;
            generate-subtitles => { root.generate-subtitles-requested(); }
            select-model => { root.select-whisper-model-requested(); }
            select-ollama-model => { root.select-ollama-model-requested(); }
            set-ollama-target-language(text) => { root.set-ollama-target-language(text); }
            analyze-all-sentences => { root.analyze-all-requested(); }
            link-translation => { root.link-translation-requested(); }
            cancel => { root.cancel-open-subtitles-dialog(); }
            confirm => { root.confirm-open-subtitles-dialog(); }
        }

        // Rendered before the model pickers below so that opening one of
        // them from inside the Settings dialog (select-whisper-model/
        // select-ollama-model) layers the picker on top rather than
        // underneath — same document-order convention as
        // OpenSubtitlesDialog above and the pickers it also reaches.
        if root.is-settings-dialog-open : SettingsDialog {
            width: parent.width;
            height: parent.height;
            config-path: root.settings-config-path;
            video-folder: root.settings-video-folder;
            whisper-model-selected: root.whisper-model-selected;
            whisper-model-name: root.whisper-model-name;
            ollama-model-selected: root.ollama-model-selected;
            ollama-model-name: root.ollama-model-name;
            ollama-target-language: root.ollama-target-language;
            audio-monitor-source: root.settings-audio-monitor-source;
            audio-recording-folder: root.settings-audio-recording-folder;
            audio-recording-folder-exists: root.settings-audio-recording-folder-exists;
            niqud-model-selected: root.niqud-model-selected;
            niqud-model-name: root.niqud-model-name;
            niqud-model-needs-restart: root.niqud-model-needs-restart;
            set-video-folder(text) => { root.set-settings-video-folder(text); }
            select-whisper-model => { root.select-whisper-model-requested(); }
            select-ollama-model => { root.select-ollama-model-requested(); }
            set-ollama-target-language(text) => { root.set-ollama-target-language(text); }
            set-audio-monitor-source(text) => { root.set-settings-audio-monitor-source(text); }
            set-audio-recording-folder(text) => { root.set-settings-audio-recording-folder(text); }
            select-niqud-model => { root.select-niqud-model-requested(); }
            close => { root.close-settings-dialog(); }
        }

        // Rendered after OpenSubtitlesDialog so it layers on top when both
        // are open — the translation-link picker is reached from inside
        // the already-open Open Subtitles dialog.
        if root.is-link-translation-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Link translation subtitle";
            confirm-label: "Link";
            folder-label: root.link-translation-folder-label;
            rows: root.link-translation-rows;
            selected-index: root.link-translation-selected-index;
            row-clicked(index) => { root.select-link-translation-row(index); }
            cancel => { root.cancel-link-translation-dialog(); }
            confirm => { root.confirm-link-translation(); }
        }

        // Also reached from inside the Open Subtitles dialog, same as the
        // translation-link picker above.
        if root.is-model-picker-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Select whisper model";
            confirm-label: "Select";
            folder-label: root.model-picker-folder-label;
            rows: root.model-picker-rows;
            selected-index: root.model-picker-selected-index;
            row-clicked(index) => { root.select-model-picker-row(index); }
            cancel => { root.cancel-model-picker-dialog(); }
            confirm => { root.confirm-model-picker-dialog(); }
        }

        // Only reachable from the Settings dialog (no Open Subtitles
        // dialog row, unlike the whisper/Ollama pickers above).
        if root.is-niqud-model-picker-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Select Hebrew niqud model";
            confirm-label: "Select";
            folder-label: root.niqud-model-picker-folder-label;
            rows: root.niqud-model-picker-rows;
            selected-index: root.niqud-model-picker-selected-index;
            row-clicked(index) => { root.select-niqud-model-picker-row(index); }
            cancel => { root.cancel-niqud-model-picker-dialog(); }
            confirm => { root.confirm-niqud-model-picker-dialog(); }
        }

        // Also reached from inside the Open Subtitles dialog, same as the
        // whisper model picker above — but lists Ollama models rather than
        // browsing a folder, so folder-label doubles as a loading/error
        // status line instead of a path.
        if root.is-ollama-model-picker-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Select Ollama model";
            confirm-label: "Select";
            folder-label: root.ollama-model-picker-loading
                ? "Loading models…"
                : (root.ollama-model-picker-error != "" ? root.ollama-model-picker-error : "Installed Ollama models");
            rows: root.ollama-model-picker-rows;
            selected-index: root.ollama-model-picker-selected-index;
            row-clicked(index) => { root.select-ollama-model-picker-row(index); }
            cancel => { root.cancel-ollama-model-picker-dialog(); }
            confirm => { root.confirm-ollama-model-picker-dialog(); }
        }

        // Rendered last so it layers on top of everything else — Ctrl+A
        // can be pressed from the main player screen regardless of which
        // (if any) other dialog happens to be open.
        if root.is-word-analysis-popup-open : WordAnalysisPopup {
            width: parent.width;
            height: parent.height;
            status: root.word-analysis-status;
            rows: root.word-analysis-rows;
            error-message: root.word-analysis-error-message;
            close => { root.close-word-analysis-popup(); }
        }

        if root.is-word-timing-popup-open : WordTimingPopup {
            width: parent.width;
            height: parent.height;
            status: root.word-timing-status;
            rows: root.word-timing-rows;
            error-message: root.word-timing-error-message;
            close => { root.close-word-timing-popup(); }
            play(start-seconds, end-seconds) => { root.play-word-timing(start-seconds, end-seconds); }
        }
    }
}
