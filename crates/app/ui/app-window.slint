// TrangoPlayer main window shell.
//
// Top bar in its full visual form per README.md's design tokens (wordmark,
// segmented control, ghost buttons) — pixel reference is
// sketch/design_reference.dc.html#1c. The segmented control's `toggle-mode`
// callback is handled in Rust (crates/app/src/main.rs), which drives
// playback-state::PlayerState::toggle_mode() and mirrors the result back
// into `sentence-mode-active`. Body/bottom-hint-bar content arrives in
// later steps.

import { LineEdit, ListView, ScrollView } from "std-widgets.slint";

/// Color tokens from README.md's "Design Tokens" section, shared across the
/// top bar components below.
global Palette {
    out property <color> window-bg: #1c1d22;
    out property <color> panel-bg: #202127;
    out property <color> border: #3a3c45;
    out property <color> accent: #3b6fd6;
    out property <color> primary-text: #e7e8ec;
    out property <color> muted-text: #8a8d99;
    out property <color> ghost-text: #b4b7c0;
    out property <color> segmented-bg: #2a2c33;
    out property <color> translation-text: #7fa6f0;
    out property <color> modal-bg: #22232a;
    out property <color> chip-muted: #4a4d59;
    out property <color> error-text: #e5484d;
}

/// Subtitle generation status for the Open Subtitles dialog's "Generate
/// subtitles" flow (`TODO.md` Vaihe 20, README's `subtitleGenerationStatus`).
/// Driven from Rust (`crates/app/src/subtitle_generation.rs`) as
/// `AppWindow::subtitle-generation-status`.
export enum SubtitleGenerationStatus {
    Idle,
    Generating,
    Done,
    Error,
}

/// State of the "Analyze all sentences" batch loop (`TODO.md` Vaihe 24,
/// part 4/6) — mirrors `SubtitleGenerationStatus`'s Idle/running/Done/Error
/// shape. Set from Rust by `crates/app/src/word_analysis.rs`.
export enum WordAnalysisBatchStatus {
    Idle,
    Running,
    Done,
    Error,
}

/// One pill in the top bar's Normal / Sentence-by-sentence segmented
/// control; filled with the accent color while `active`, muted otherwise.
component SegmentButton {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-radius: 5px;
        background: root.active ? Palette.accent : transparent;

        layout := HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 6px;
            padding-bottom: 6px;

            Text {
                text: root.label;
                color: root.active ? white : Palette.muted-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// Pill-shaped on/off switch used by the current-sentence card's
/// "Translation" toggle: accent-filled track with a white knob when `on`,
/// muted track with the knob on the left otherwise.
component ToggleSwitch {
    in property <bool> on;
    callback toggled;

    width: 34px;
    height: 18px;

    Rectangle {
        border-radius: self.height / 2;
        background: root.on ? Palette.accent : Palette.segmented-bg;
        border-width: 1px;
        border-color: Palette.border;

        Rectangle {
            width: 14px;
            height: 14px;
            border-radius: self.height / 2;
            background: white;
            y: (parent.height - self.height) / 2;
            x: root.on ? parent.width - self.width - 2px : 2px;

            animate x { duration: 120ms; easing: ease-out; }
        }

        TouchArea {
            clicked => { root.toggled(); }
        }
    }
}

/// A bordered, no-fill "Open video…" / "Open subtitles…" top bar button.
/// "Open video…" is wired to the Open Video dialog (Vaihe 18); "Open
/// subtitles…" to the Open Subtitles dialog (Vaihe 19) — both are
/// `FileListDialog` instances, see below.
component GhostButton {
    in property <string> label;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-width: 1px;
        border-radius: 6px;
        border-color: Palette.border;

        layout := HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 7px;
            padding-bottom: 7px;

            Text {
                text: root.label;
                color: Palette.ghost-text;
                font-family: "JetBrains Mono";
                font-size: 12px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// The right-hand sentence panel's top card: "Sentence N / M" (uppercase,
/// mono, muted) left / "Translation" label + toggle switch right, above the
/// current cue's original-language text, a divider, and (while
/// `show-translation` is on) the translation text in accent-tinted blue.
/// `sentence-label`/`sentence-text`/`has-sentence`/`translation-text` are
/// set from Rust: `main.rs` after loading a subtitle file, and
/// `video_player.rs`'s scrub bar poll (while in `SentenceBySentence` mode,
/// synced from mpv's `time-pos`) — see `crates/app/src/sentence_card.rs`.
/// `show-translation` is wired directly to `main.rs`'s `toggle-translation`
/// callback (see `wire_player_state`), independent of cue changes. The
/// sentence-list card underneath it arrives in a later TODO.md step.
component CurrentSentenceCard {
    in property <string> sentence-label;
    in property <string> sentence-text;
    in property <bool> has-sentence;
    in property <string> translation-text;
    in property <bool> show-translation;
    callback toggle-translation;

    /// Fixed height for the translation line's scroll area — roughly 3
    /// lines of the 18px/500 Inter translation text. Fixed rather than
    /// sized to content so the card (and, below it, the sentence list's
    /// available height) doesn't visibly grow/shrink every time the
    /// current cue's translation changes length; longer translations
    /// scroll inside this box instead.
    property <length> translation-height: 84px;

    Rectangle {
        border-width: 1px;
        border-radius: 8px;
        border-color: Palette.border;
        background: Palette.panel-bg;

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                alignment: space-between;
                cross-axis-alignment: center;

                Text {
                    text: root.sentence-label;
                    color: Palette.muted-text;
                    font-family: "JetBrains Mono";
                    font-size: 10px;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: 8px;
                    cross-axis-alignment: center;

                    Text {
                        text: "Translation";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 12px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }

                    ToggleSwitch {
                        on: root.show-translation;
                        toggled => { root.toggle-translation(); }
                    }
                }
            }

            Text {
                text: root.sentence-text;
                color: root.has-sentence ? Palette.primary-text : Palette.muted-text;
                font-family: "Inter";
                font-size: 24px;
                font-weight: 600;
                wrap: word-wrap;
            }

            Rectangle {
                height: 1px;
                background: Palette.border;
            }

            if root.show-translation : ScrollView {
                height: root.translation-height;

                Text {
                    text: root.translation-text;
                    color: Palette.translation-text;
                    font-family: "Inter";
                    font-size: 18px;
                    font-weight: 500;
                    wrap: word-wrap;
                    width: parent.width;
                }
            }
        }
    }
}

/// One row in the sentence list: `"index · text"`, plus whether it's the
/// currently focused cue (highlighted with an accent-tinted pill).
struct SentenceListRow {
    label: string,
    is-current: bool,
}

/// The right-hand sentence panel's scrollable "all cues" list, underneath
/// `CurrentSentenceCard`. `rows`/`current-index` are set from Rust
/// (`crates/app/src/sentence_list.rs`) whenever the loaded cues or the
/// current cue change. Clicking a row emits `row-clicked` with that row's
/// index, which `main.rs` wires to the same `playback-state::jump_to_cue`
/// navigation used by arrow-key navigation — see README's "Sentence list"
/// interaction spec.
component SentenceListCard inherits Rectangle {
    in property <[SentenceListRow]> rows: [];
    in property <int> current-index: -1;
    callback row-clicked(int);

    /// Fixed row height, matched by `row-y`/`bring-into-view` below so the
    /// scroll-into-view math doesn't need to measure text layout.
    property <length> row-height: 32px;

    border-width: 1px;
    border-radius: 8px;
    border-color: Palette.border;
    background: Palette.panel-bg;

    VerticalLayout {
        padding: 12px;
        spacing: 4px;

        Text {
            text: "Sentence list";
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 10px;
            font-weight: 600;
        }

        list := ListView {
            for row[index] in root.rows : Rectangle {
                height: root.row-height;
                border-radius: 6px;
                background: row.is-current ? Palette.accent.with-alpha(0.22) : transparent;

                Text {
                    text: row.label;
                    color: row.is-current ? Palette.primary-text : Palette.muted-text;
                    font-family: "Inter";
                    font-size: 13px;
                    font-weight: 500;
                    overflow: elide;
                    x: 10px;
                    width: parent.width - 20px;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.row-clicked(index); }
                }
            }
        }
    }

    /// The current row's y position within `list`'s scrolled viewport —
    /// negative/beyond `visible-height` means it's currently out of view.
    pure function row-y(index: int) -> length {
        return list.viewport-y + index * root.row-height;
    }

    /// Scrolls `list` just enough to bring row `index` fully into view,
    /// without otherwise disturbing the current scroll position.
    function bring-into-view(index: int) {
        if (row-y(index) < 0) {
            list.viewport-y += 0 - row-y(index);
        }
        if (row-y(index) + root.row-height > list.visible-height) {
            list.viewport-y -= row-y(index) + root.row-height - list.visible-height;
        }
    }

    changed current-index => {
        if (root.current-index < 0 || root.current-index >= root.rows.length) {
            return;
        }
        root.bring-into-view(root.current-index);
    }
}

/// One row in a `FileListDialog` listing: either a navigable row (the
/// "‥ Up" row or a subfolder — `is-navigable`, no `size-label`, never
/// `is-selected`; clicking it navigates the dialog to a different folder)
/// or a selectable file (`is-selected` driving the accent-tinted
/// background/chip color). Set from Rust in
/// `crates/app/src/open_video_dialog.rs` (video files, with folder
/// navigation) and `crates/app/src/open_subtitles_dialog.rs` (translation
/// `.srt` files, flat — see `FileListDialog`'s doc comment on why the same
/// row shape covers both).
struct FileListRow {
    name: string,
    size-label: string,
    is-selected: bool,
    is-navigable: bool,
}

/// A generic file-picker modal: header (`title` + "✕"), a scrollable list
/// of `rows` under `folder-label`, and a footer with "Cancel" + a filled
/// `confirm-label` button. Used for both the Open Video dialog (`TODO.md`
/// Vaihe 18 — pixel reference `sketch/design_reference.dc.html#2a`, left
/// mock, extended here with in-dialog folder navigation not shown in that
/// static mock) and the Open Subtitles dialog's translation-link picker
/// (Vaihe 19, see `OpenSubtitlesDialog` below) — both are "browse a
/// folder's files and pick one", just scoped to different extensions and
/// (for the video dialog only) with subfolder navigation.
/// `folder-label`/`rows`/`selected-index` are set from Rust when the
/// dialog opens and again whenever a navigable row changes the listed
/// folder. Clicking a row emits `row-clicked` with its index — the Rust
/// side decides whether that navigates (an `Up`/`Folder` row) or selects
/// (a file row); the backdrop, header "✕", and footer "Cancel" all emit
/// `cancel`; footer `confirm-label` emits `confirm` (a no-op while nothing
/// is selected).
component FileListDialog {
    in property <string> title;
    in property <string> confirm-label;
    in property <string> folder-label;
    in property <[FileListRow]> rows: [];
    in property <int> selected-index: -1;
    callback row-clicked(int);
    callback cancel();
    callback confirm();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            // Clicking the dimmed backdrop cancels, same as the header's
            // close button and footer's Cancel button.
            clicked => { root.cancel(); }
        }

        Rectangle {
            width: 640px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's cancel handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: root.title;
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.cancel(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 16px;
                    spacing: 6px;

                    Text {
                        text: root.folder-label;
                        color: Palette.muted-text;
                        font-family: "JetBrains Mono";
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 0.8px;
                    }

                    if root.rows.length == 0 : Text {
                        text: "This folder is empty.";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 13px;
                    }

                    ListView {
                        for row[index] in root.rows : Rectangle {
                            height: 44px;
                            border-radius: 7px;
                            background: row.is-selected ? Palette.accent.with-alpha(0.22) : transparent;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 10px;
                                cross-axis-alignment: center;

                                if !row.is-navigable : Rectangle {
                                    width: 28px;
                                    height: 20px;
                                    border-radius: 3px;
                                    background: row.is-selected ? Palette.accent : Palette.chip-muted;
                                }

                                VerticalLayout {
                                    alignment: center;

                                    Text {
                                        text: row.name;
                                        color: row.is-selected ? Palette.primary-text : Palette.ghost-text;
                                        font-family: "Inter";
                                        font-size: 13px;
                                        font-weight: row.is-navigable ? 600 : 500;
                                        overflow: elide;
                                    }

                                    if row.size-label != "" : Text {
                                        text: row.size-label;
                                        color: Palette.muted-text;
                                        font-family: "JetBrains Mono";
                                        font-size: 11px;
                                    }
                                }
                            }

                            TouchArea {
                                clicked => { root.row-clicked(index); }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        spacing: 10px;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Cancel";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.cancel(); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;
                            opacity: root.selected-index >= 0 ? 1.0 : 0.5;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: root.confirm-label;
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    if (root.selected-index >= 0) {
                                        root.confirm();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// One word's analysis in the Ctrl+A popup below: the word as it appears
/// in the sentence, its translation, and a pronunciation guide. Mirrors
/// `word_analysis::WordEntry` (`crates/word-analysis/src/entry.rs`), set
/// from Rust by `crates/app/src/word_analysis.rs`.
struct WordAnalysisRow {
    word: string,
    translation: string,
    pronunciation: string,
}

/// State of the Ctrl+A word-analysis popup (`TODO.md` Vaihe 24, part 5/6)
/// — `Idle` before it's ever been opened, `Loading` while a background
/// Ollama call for an uncached sentence is in flight, `Done` once
/// `word-analysis-rows` has content to show, `Error` (with
/// `word-analysis-error-message`) if no model/subtitle is available or
/// the Ollama call failed.
export enum WordAnalysisStatus {
    Idle,
    Loading,
    Done,
    Error,
}

/// Ctrl+A's word-by-word analysis popup for the sentence currently shown
/// in the current-sentence card: header ("Word analysis" + "✕"), a
/// scrollable list of `word · translation · pronunciation` rows (or a
/// loading/error message in place of the list), footer "Close". Opened by
/// `AppWindow`'s `show-word-analysis` (wired in `main.rs`'s
/// `wire_word_analysis_popup` to Ctrl+A, see `nav-focus`'s `key-pressed`
/// below); closed by the backdrop, header "✕", or footer "Close", all
/// emitting `close`.
component WordAnalysisPopup {
    in property <WordAnalysisStatus> status: WordAnalysisStatus.Idle;
    in property <[WordAnalysisRow]> rows: [];
    in property <string> error-message: "";
    callback close();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            clicked => { root.close(); }
        }

        Rectangle {
            width: 480px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's close handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: "Word analysis";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.close(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 16px;
                    spacing: 6px;

                    if root.status == WordAnalysisStatus.Loading : Text {
                        text: "Analyzing…";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 13px;
                    }

                    if root.status == WordAnalysisStatus.Error : Text {
                        text: root.error-message;
                        color: Palette.error-text;
                        font-family: "Inter";
                        font-size: 13px;
                        wrap: word-wrap;
                    }

                    if root.status == WordAnalysisStatus.Done : ListView {
                        for row in root.rows : Rectangle {
                            height: 56px;
                            border-radius: 7px;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 10px;
                                cross-axis-alignment: center;

                                VerticalLayout {
                                    alignment: center;

                                    Text {
                                        text: row.word;
                                        color: Palette.primary-text;
                                        font-family: "Inter";
                                        font-size: 15px;
                                        font-weight: 600;
                                    }

                                    Text {
                                        text: row.pronunciation;
                                        color: Palette.muted-text;
                                        font-family: "JetBrains Mono";
                                        font-size: 11px;
                                    }
                                }

                                Text {
                                    text: row.translation;
                                    color: Palette.translation-text;
                                    font-family: "Inter";
                                    font-size: 14px;
                                    font-weight: 500;
                                    horizontal-stretch: 1;
                                    horizontal-alignment: right;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Close";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.close(); }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// Bottom hint bar shown only in `SentenceBySentence` mode (see the `if`
/// guard where it's instantiated in `AppWindow`), listing the Right/Left/
/// Space keyboard shortcuts plus Ctrl+T. Right/Left/Space are handled by
/// `AppWindow`'s `key-pressed` callback and drive
/// `next-cue`/`previous-cue`/`repeat-cue`, wired to `playback-state`
/// navigation and mpv seeking in `crates/app/src/main.rs` and
/// `video_player.rs`. Ctrl+T calls `toggle-translation` directly, and Space
/// (play/pause) also works outside `SentenceBySentence` mode — both are
/// just only *advertised* here since this is the app's only hint surface
/// so far (`Normal` mode's own hint bar content is `TODO.md` Vaihe 21,
/// still open).
component HintBar {
    height: 34px;

    Rectangle {
        background: Palette.window-bg;
        border-width: 1px;
        border-color: Palette.border;

        HorizontalLayout {
            alignment: center;
            spacing: 24px;

            Text {
                text: "← previous sentence";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                text: "space · repeat sentence";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                text: "→ next sentence";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                text: "ctrl+t · toggle translation";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }
    }
}

/// Time / progress control below the video frame: current time (mono,
/// muted) — 4px track with accent-filled progress and a white circular
/// thumb — total time (mono, muted). `current-time-label`/`duration-label`
/// and `progress` (0.0–1.0) are set from Rust, which polls mpv's
/// `time-pos`/`duration` properties (see `video_player.rs`).
component ScrubBar {
    in property <string> current-time-label;
    in property <string> duration-label;
    in property <float> progress: 0.0;

    height: 32px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 10px;
        cross-axis-alignment: center;

        Text {
            text: root.current-time-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }

        track := Rectangle {
            height: 4px;
            border-radius: 2px;
            background: Palette.border;

            Rectangle {
                x: 0px;
                width: parent.width * root.progress;
                height: parent.height;
                border-radius: 2px;
                background: Palette.accent;
            }

            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: white;
                x: parent.width * root.progress - self.width / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        Text {
            text: root.duration-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
}

/// A subtitle file already linked to the video: small accent chip + name +
/// muted "linked" tag. Used by `OpenSubtitlesDialog` for both the
/// original-language and translation sections once a file is set — per
/// README, both get "the same visual treatment" once linked.
component LinkedFileRow {
    in property <string> file-name;

    Rectangle {
        border-radius: 7px;
        background: Palette.accent.with-alpha(0.14);

        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 10px;
            padding-bottom: 10px;
            spacing: 10px;
            cross-axis-alignment: center;

            Rectangle {
                width: 24px;
                height: 18px;
                border-radius: 3px;
                background: Palette.accent;
            }

            Text {
                text: root.file-name;
                color: Palette.primary-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 500;
                horizontal-stretch: 1;
                overflow: elide;
            }

            Text {
                text: "linked";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
            }
        }
    }
}

/// An unlinked-file placeholder row: muted border, `label` text — used by
/// `OpenSubtitlesDialog`'s original section (no subtitle found) and
/// translation section (nothing linked yet). Pixel reference
/// `sketch/design_reference.dc.html#2a`'s dashed empty state; Slint has no
/// dashed-border support, so this approximates it with a solid muted
/// border instead.
component EmptyFileRow {
    in property <string> label;

    Rectangle {
        border-width: 1.5px;
        border-radius: 7px;
        border-color: Palette.chip-muted;

        HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 12px;
            padding-bottom: 12px;

            Text {
                text: root.label;
                color: Palette.muted-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }
    }
}

/// The Open Subtitles dialog (`TODO.md` Vaihe 19): a modal scoped to the
/// currently open video — pixel reference
/// `sketch/design_reference.dc.html#2a`, right mock. `title`/
/// `original-linked`/`original-name`/`translation-linked`/`translation-name`
/// are set from Rust (`crates/app/src/open_subtitles_dialog.rs`) when the
/// top bar's "Open subtitles…" button is clicked. The original-language
/// section shows a `LinkedFileRow` if found on disk, else an empty-state
/// row whose text and "Generate subtitles"/"Generating…"/"Try again"
/// button reflect `generation-status` (`TODO.md` Vaihe 20) — clicking it
/// emits `generate-subtitles`, wired in `main.rs` to
/// `subtitle_generation::generate`. The translation
/// section always shows either state too, plus a small "link…" text below
/// it — clicking either opens `main.rs`'s link-translation file picker
/// (`link-translation`), since real OS drag-and-drop isn't available (see
/// `AppWindow`'s `link-translation-requested` doc comment). Backdrop,
/// header "✕", and footer "Cancel" all emit `cancel`; footer "Done" emits
/// `confirm` — both just close the modal, see `AppWindow`'s
/// `cancel-open-subtitles-dialog`/`confirm-open-subtitles-dialog` doc
/// comment for why nothing more needs to happen on "Done".
component OpenSubtitlesDialog {
    in property <string> title;
    in property <bool> original-linked;
    in property <string> original-name;
    in property <SubtitleGenerationStatus> generation-status: SubtitleGenerationStatus.Idle;
    in property <string> generation-error-message: "";
    in property <bool> model-selected: false;
    in property <string> model-name: "";
    in property <bool> translation-linked;
    in property <string> translation-name;
    in property <bool> ollama-model-selected: false;
    in property <string> ollama-model-name: "";
    in property <string> ollama-target-language: "";
    in property <WordAnalysisBatchStatus> word-analysis-batch-status: WordAnalysisBatchStatus.Idle;
    in property <int> word-analysis-batch-progress-current: 0;
    in property <int> word-analysis-batch-progress-total: 0;
    in property <string> word-analysis-batch-error-message: "";
    callback generate-subtitles();
    callback select-model();
    callback select-ollama-model();
    callback set-ollama-target-language(string);
    callback analyze-all-sentences();
    callback link-translation();
    callback cancel();
    callback confirm();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            clicked => { root.cancel(); }
        }

        Rectangle {
            width: 640px;
            height: 560px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's cancel handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: root.title;
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.cancel(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 20px;
                    spacing: 16px;

                    VerticalLayout {
                        spacing: 8px;

                        Text {
                            text: "Original subtitle";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        if root.original-linked : LinkedFileRow {
                            file-name: root.original-name;
                        }

                        if !root.original-linked : Rectangle {
                            border-width: 1.5px;
                            border-radius: 7px;
                            border-color: Palette.chip-muted;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 10px;
                                padding-bottom: 10px;
                                alignment: space-between;
                                cross-axis-alignment: center;

                                Text {
                                    text: root.generation-status == SubtitleGenerationStatus.Generating
                                        ? "Generating…"
                                        : root.generation-status == SubtitleGenerationStatus.Error
                                            ? "Generation failed"
                                            : "No subtitle file found";
                                    color: root.generation-status == SubtitleGenerationStatus.Error
                                        ? Palette.error-text
                                        : Palette.muted-text;
                                    font-family: "Inter";
                                    font-size: 13px;
                                    font-weight: 500;
                                    vertical-alignment: center;
                                }

                                Rectangle {
                                    border-radius: 6px;
                                    background: Palette.accent;
                                    opacity: root.generation-status == SubtitleGenerationStatus.Generating || !root.model-selected ? 0.55 : 1.0;

                                    HorizontalLayout {
                                        padding-left: 14px;
                                        padding-right: 14px;
                                        padding-top: 8px;
                                        padding-bottom: 8px;

                                        Text {
                                            text: root.generation-status == SubtitleGenerationStatus.Generating
                                                ? "Generating…"
                                                : root.generation-status == SubtitleGenerationStatus.Error
                                                    ? "Try again"
                                                    : "Generate subtitles";
                                            color: white;
                                            font-family: "Inter";
                                            font-size: 12px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                        }
                                    }

                                    TouchArea {
                                        enabled: root.generation-status != SubtitleGenerationStatus.Generating && root.model-selected;
                                        clicked => { root.generate-subtitles(); }
                                    }
                                }
                            }
                        }

                        if !root.original-linked : Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.model-selected
                                        ? "whisper model: " + root.model-name + " (change)"
                                        : "select a whisper model to enable generation…";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 11px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-model(); }
                            }
                        }

                        if root.generation-status == SubtitleGenerationStatus.Error && root.generation-error-message != "" : Text {
                            text: root.generation-error-message;
                            color: Palette.error-text;
                            font-family: "Inter";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;

                        Text {
                            text: "Translation";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        if root.translation-linked : LinkedFileRow {
                            file-name: root.translation-name;
                        }

                        if !root.translation-linked : EmptyFileRow {
                            label: "No translation linked";
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.translation-linked
                                        ? "change linked translation file…"
                                        : "click to link a translation .srt file";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 11px;
                                    font-weight: 500;
                                }
                            }

                            TouchArea {
                                clicked => { root.link-translation(); }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 6px;

                        Text {
                            text: "Word analysis (Ollama)";
                            color: Palette.muted-text;
                            font-family: "JetBrains Mono";
                            font-size: 10px;
                            font-weight: 600;
                            letter-spacing: 0.8px;
                        }

                        Rectangle {
                            HorizontalLayout {
                                Text {
                                    text: root.ollama-model-selected
                                        ? "Ollama model: " + root.ollama-model-name + " (change)"
                                        : "select an Ollama model for word analysis…";
                                    color: Palette.accent;
                                    font-family: "Inter";
                                    font-size: 11px;
                                    font-weight: 500;
                                    wrap: word-wrap;
                                }
                            }

                            TouchArea {
                                clicked => { root.select-ollama-model(); }
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            cross-axis-alignment: center;

                            Text {
                                text: "Target language:";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 11px;
                                font-weight: 500;
                                vertical-alignment: center;
                            }

                            LineEdit {
                                horizontal-stretch: 1;
                                text: root.ollama-target-language;
                                placeholder-text: "e.g. English";
                                font-size: 12px;
                                edited(text) => { root.set-ollama-target-language(text); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;
                            opacity: root.word-analysis-batch-status == WordAnalysisBatchStatus.Running || !root.ollama-model-selected ? 0.55 : 1.0;

                            HorizontalLayout {
                                padding-left: 14px;
                                padding-right: 14px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: root.word-analysis-batch-status == WordAnalysisBatchStatus.Running
                                        ? "Analyzing " + root.word-analysis-batch-progress-current + " / " + root.word-analysis-batch-progress-total + "…"
                                        : root.word-analysis-batch-status == WordAnalysisBatchStatus.Error
                                            ? "Try again"
                                            : root.word-analysis-batch-status == WordAnalysisBatchStatus.Done
                                                ? "Analyzed all sentences"
                                                : "Analyze all sentences";
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                enabled: root.word-analysis-batch-status != WordAnalysisBatchStatus.Running && root.ollama-model-selected;
                                clicked => { root.analyze-all-sentences(); }
                            }
                        }

                        if root.word-analysis-batch-status == WordAnalysisBatchStatus.Error && root.word-analysis-batch-error-message != "" : Text {
                            text: root.word-analysis-batch-error-message;
                            color: Palette.error-text;
                            font-family: "Inter";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }

                    Rectangle {
                        height: 1px;
                        background: Palette.border;
                    }

                    Text {
                        text: "Generating uses on-device speech recognition — no upload.";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 12px;
                        font-weight: 500;
                        wrap: word-wrap;
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        spacing: 10px;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Cancel";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.cancel(); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Done";
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.confirm(); }
                            }
                        }
                    }
                }
            }
        }
    }
}

export component AppWindow inherits Window {
    in property <string> version;
    in property <bool> sentence-mode-active: false;
    // Whether crates/app/src/video_player.rs has an mpv OpenGL render
    // context underlay active. While true, the video area below is left
    // fully transparent so that underlay (drawn straight into the window's
    // backbuffer before this scene, via Window::set_rendering_notifier) is
    // visible through it; opaque window-bg is only needed as a placeholder
    // when no video is loaded yet.
    in property <bool> video-loaded: false;
    // The video frame Rectangle's resolved on-screen geometry, relative to
    // this window — read by `video_player.rs`'s `render_frame` each frame so
    // the mpv underlay it draws can be confined to exactly this box (via an
    // offscreen FBO + blit) rather than the whole window. Summed from the
    // named ancestors' own `x`/`y` (each relative to *its* parent) since
    // Slint has no built-in "position relative to window" accessor; safe
    // here because every ancestor above `body-row` sits at (0, 0) with no
    // padding of its own, so `body-row.x`/`.y` already are window-relative.
    out property <length> video-frame-x: body-row.x + video-column.x + video-frame.x;
    out property <length> video-frame-y: body-row.y + video-column.y + video-frame.y;
    out property <length> video-frame-width: video-frame.width;
    out property <length> video-frame-height: video-frame.height;
    // Scrub bar state, polled from mpv's `time-pos`/`duration` properties in
    // video_player.rs and formatted via playback_state::format_time.
    in property <string> current-time-label: "00:00";
    in property <string> duration-label: "00:00";
    in property <float> scrub-progress: 0.0;
    // Current-sentence card state, mirrored from playback_state::PlayerState
    // by crates/app/src/sentence_card.rs — see CurrentSentenceCard above.
    in property <string> sentence-label: "Sentence – / –";
    in property <string> sentence-text: "No sentence loaded.";
    in property <bool> has-current-sentence: false;
    in property <string> translation-text: "";
    // Whether the current-sentence card's translation line is shown,
    // mirrored from playback_state::PlayerState.show_translation by
    // main.rs's wire_player_state — flipped by the toggle-translation
    // callback below, off by default.
    in property <bool> show-translation: false;
    // Sentence list state, mirrored from playback_state::PlayerState by
    // crates/app/src/sentence_list.rs — see SentenceListCard above.
    in property <[SentenceListRow]> sentence-list-rows: [];
    in property <int> sentence-list-current-index: -1;
    callback toggle-mode();
    // Invoked by the current-sentence card's Translation toggle switch —
    // wired in main.rs's wire_player_state to
    // playback_state::PlayerState::toggle_translation().
    callback toggle-translation();
    // Sentence-by-sentence navigation, invoked by `nav-focus`'s key-pressed
    // handler below for Right/Left (SentenceBySentence mode only) and
    // Space (both modes, repeat-cue only) respectively — see
    // `crates/app/src/main.rs` for how they drive `playback-state` and mpv.
    callback next-cue();
    callback previous-cue();
    callback repeat-cue();
    // Sentence list row click, invoked by SentenceListCard with the clicked
    // row's index — wired in main.rs to playback_state::jump_to_cue, the
    // same navigation call arrow keys drive.
    callback jump-to-cue(int);
    // Open Video dialog state (TODO.md Vaihe 18), set from Rust by
    // crates/app/src/open_video_dialog.rs — see FileListDialog above.
    in property <bool> is-open-video-dialog-open: false;
    in property <string> open-video-folder-label: "";
    in property <[FileListRow]> open-video-rows: [];
    in property <int> open-video-selected-index: -1;
    // Invoked by the top bar's "Open video…" GhostButton; wired in main.rs's
    // wire_open_video_dialog to list the default folder's video files and
    // open the dialog.
    callback open-video-dialog-requested();
    // Invoked by the dialog's backdrop click / "✕" / "Cancel" — closes it.
    callback cancel-open-video-dialog();
    // Invoked by a dialog row click, with that row's index — marks it
    // selected.
    callback select-open-video-row(int);
    // Invoked by the dialog's "Open" button — loads the selected file.
    callback confirm-open-video();
    // Open Subtitles dialog state (TODO.md Vaihe 19), set from Rust by
    // crates/app/src/open_subtitles_dialog.rs — see OpenSubtitlesDialog
    // below.
    in property <bool> is-open-subtitles-dialog-open: false;
    in property <string> open-subtitles-title: "";
    in property <bool> open-subtitles-original-linked: false;
    in property <string> open-subtitles-original-name: "";
    in property <bool> open-subtitles-translation-linked: false;
    in property <string> open-subtitles-translation-name: "";
    // Invoked by the top bar's "Open subtitles…" GhostButton.
    callback open-subtitles-dialog-requested();
    // Invoked by the dialog's backdrop click / "✕" / "Cancel" / "Done" —
    // all just close it: the original subtitle (if found) is already
    // loaded by the time the dialog opens, and a linked translation is
    // applied immediately when picked (see link-translation-requested
    // below), so there's nothing left to apply on "Done".
    callback cancel-open-subtitles-dialog();
    callback confirm-open-subtitles-dialog();
    // Invoked by the original-language section's "Generate subtitles"
    // button (TODO.md Vaihe 20/21.5) — wired in main.rs's
    // wire_open_subtitles_dialog to subtitle::WhisperCliGenerator, run on a
    // background thread (real transcription can take minutes) via
    // subtitle_generation::spawn_generate. Its result is mirrored back into
    // subtitle-generation-status/-error-message below and, on success, the
    // original row via open_subtitles_dialog::mark_original_linked.
    callback generate-subtitles-requested();
    // Idle/Generating/Done/Error for the flow above, set from Rust by
    // crates/app/src/subtitle_generation.rs. Reset to Idle each time the
    // Open Subtitles dialog opens (open_subtitles_dialog::open_dialog).
    in property <SubtitleGenerationStatus> subtitle-generation-status: SubtitleGenerationStatus.Idle;
    // Human-readable failure reason for the Error state above (e.g.
    // "whisper-cli not found (looked for ...) — install whisper.cpp..."),
    // shown in place of a generic "Generation failed" message. Empty
    // outside the Error state; reset alongside subtitle-generation-status.
    in property <string> subtitle-generation-error-message: "";
    // Internal signal, not tied to any UI element: invoked from Rust
    // (main.rs's generate-subtitles-requested handler) once a background
    // whisper-cli run finishes successfully, carrying the new subtitle's
    // path. Exists because the handler's `slint::invoke_from_event_loop`
    // callback (dispatched from a background thread, so it may only
    // capture `Send` data — a `Weak<AppWindow>` plus this path string) has
    // no way to reach the `Rc<RefCell<PlayerState>>`/`Rc<RefCell<CurrentMedia>>`
    // that loading the subtitle into the player needs; invoking this
    // callback hands off to a handler set up once on the UI thread
    // (`wire_open_subtitles_dialog`) that does have them.
    callback subtitle-generated(string);
    // Invoked by the translation section's "click to link…" text. Opens
    // the link-translation file picker below rather than accepting an
    // OS-level file drop like the design mock: Slint 1.17.1's winit
    // backend doesn't relay external file drops to `DropArea`, only
    // in-app `DragArea` sources, of which this dialog has none.
    callback link-translation-requested();
    // The translation-link file picker (a FileListDialog scoped to the
    // video's folder's .srt files), set from Rust by
    // crates/app/src/open_subtitles_dialog.rs.
    in property <bool> is-link-translation-dialog-open: false;
    in property <string> link-translation-folder-label: "";
    in property <[FileListRow]> link-translation-rows: [];
    in property <int> link-translation-selected-index: -1;
    callback select-link-translation-row(int);
    callback cancel-link-translation-dialog();
    callback confirm-link-translation();
    // Whisper model selection (TODO.md Vaihe 21.6): which ggml/gguf model
    // "Generate subtitles" runs `subtitle::WhisperCliGenerator` against.
    // Set from Rust by crates/app/src/model_picker.rs; persisted across
    // restarts by crates/app/src/config.rs.
    in property <bool> whisper-model-selected: false;
    in property <string> whisper-model-name: "";
    // Invoked by the Open Subtitles dialog's model row. Opens the model
    // picker (a FileListDialog scoped to .bin/.gguf files, same chrome as
    // the Open Video dialog), starting from an autodiscovered or
    // previously-picked folder (model_picker::default_start_folder).
    callback select-whisper-model-requested();
    in property <bool> is-model-picker-dialog-open: false;
    in property <string> model-picker-folder-label: "";
    in property <[FileListRow]> model-picker-rows: [];
    in property <int> model-picker-selected-index: -1;
    callback select-model-picker-row(int);
    callback cancel-model-picker-dialog();
    callback confirm-model-picker-dialog();
    // Ollama model selection (TODO.md Vaihe 24): which locally installed
    // Ollama model the Ctrl+A popup and "Analyze all sentences" batch loop
    // run word-by-word sentence analysis against. Set from Rust by
    // crates/app/src/ollama_model_picker.rs; persisted across restarts by
    // crates/app/src/config.rs, the same way whisper-model-selected is.
    in property <bool> ollama-model-selected: false;
    in property <string> ollama-model-name: "";
    // Invoked by the Open Subtitles dialog's Ollama model row. Opens the
    // model picker (a FileListDialog listing models Ollama reports, no
    // folder navigation — see ollama_model_picker.rs's module doc for why
    // listing runs on a background thread unlike the whisper model
    // picker's synchronous filesystem listing).
    callback select-ollama-model-requested();
    in property <bool> is-ollama-model-picker-open: false;
    in property <bool> ollama-model-picker-loading: false;
    in property <string> ollama-model-picker-error: "";
    in property <[FileListRow]> ollama-model-picker-rows: [];
    in property <int> ollama-model-picker-selected-index: -1;
    callback select-ollama-model-picker-row(int);
    callback cancel-ollama-model-picker-dialog();
    callback confirm-ollama-model-picker-dialog();
    // Target language for word analysis (TODO.md Vaihe 24.1): what
    // translations/pronunciations are produced in. Free-text field (the
    // Open Subtitles dialog's LineEdit) rather than a fixed list, since
    // any language name is valid input. Set from Rust by
    // crates/app/src/main.rs's wire_ollama_target_language; persisted
    // across restarts by crates/app/src/config.rs, the same way the
    // Ollama model is.
    in property <string> ollama-target-language: "";
    callback set-ollama-target-language(string);
    // Ctrl+A word-analysis popup (TODO.md Vaihe 24, part 5/6): analyzes the
    // sentence currently shown in the current-sentence card. Set from Rust
    // by crates/app/src/word_analysis.rs's wire_word_analysis_popup.
    callback show-word-analysis();
    callback close-word-analysis-popup();
    in property <bool> is-word-analysis-popup-open: false;
    in property <WordAnalysisStatus> word-analysis-status: WordAnalysisStatus.Idle;
    in property <[WordAnalysisRow]> word-analysis-rows: [];
    in property <string> word-analysis-error-message: "";
    // "Analyze all sentences" batch loop (TODO.md Vaihe 24, part 4/6): runs
    // word-by-word analysis for every cue not already in the subtitle's
    // cache file. Set from Rust by crates/app/src/word_analysis.rs.
    callback analyze-all-requested();
    in property <WordAnalysisBatchStatus> word-analysis-batch-status: WordAnalysisBatchStatus.Idle;
    in property <int> word-analysis-batch-progress-current: 0;
    in property <int> word-analysis-batch-progress-total: 0;
    in property <string> word-analysis-batch-error-message: "";

    title: "TrangoPlayer v" + version;
    // `preferred-width`/`-height`, not `width`/`height`: per Slint's
    // `Window` docs, binding `width`/`height` directly makes the window a
    // *fixed* size (`min-width`==`max-width` at the window-manager level) —
    // the OS-level frame could still be dragged/maximized bigger (its
    // decorations aren't Slint's concern), but Slint's own content stayed
    // clamped to this fixed size in the corner of that bigger frame,
    // leaving the rest of the window an unpainted gap. `preferred-width`/
    // `-height` only set the *initial* size and leave the window freely
    // resizable, letting the content column below (bound to `width`/
    // `height: 100%`) actually grow and shrink with it. 660px tall
    // comfortably fits the sentence panel's default content
    // (current-sentence card + at least a few sentence-list rows) plus the
    // bottom `HintBar` without either being cramped at startup.
    preferred-width: 960px;
    preferred-height: 660px;
    forward-focus: nav-focus;

    nav-focus := FocusScope {
        key-pressed(event) => {
            if (event.modifiers.control && (event.text == "t" || event.text == "T")) {
                // Translation visibility is purely visual and independent
                // of playback mode (see README), so Ctrl+T is handled
                // before the sentence-mode-active guard below, unlike
                // Right/Left which only make sense in SentenceBySentence
                // mode.
                root.toggle-translation();
                accept
            } else if (event.modifiers.control && (event.text == "a" || event.text == "A")) {
                // Word analysis targets whatever sentence the
                // current-sentence card is showing right now, same as
                // Ctrl+T above — not mode-gated for the same reason.
                root.show-word-analysis();
                accept
            } else if (event.text == " ") {
                // Space (play/pause) works in both modes — see
                // repeat-cue's doc comment for why it's the same callback
                // as Sentence-by-sentence's "replay current cue": the Rust
                // handler falls back to a plain toggle when there's no
                // current cue to bound playback to (Normal mode, or no
                // subtitle linked yet).
                root.repeat-cue();
                accept
            } else if (!root.sentence-mode-active) {
                reject
            } else if (event.text == Key.RightArrow) {
                root.next-cue();
                accept
            } else if (event.text == Key.LeftArrow) {
                root.previous-cue();
                accept
            } else {
                reject
            }
        }

        VerticalLayout {
            // `nav-focus` (a `FocusScope`, not a `Layout`) doesn't stretch an
            // arbitrary single child to fill itself the way a `Layout`
            // stretches its own children — without an explicit `width`/
            // `height` here, this column just takes its natural content
            // size (which is why `AppWindow`'s `width`/`height` above had to
            // be hand-tuned to match it) and stays that size regardless of
            // how big the actual window grows, leaving dead space around it
            // instead of the video/sentence-panel area growing into a
            // resized or maximized window.
            width: 100%;
            height: 100%;

            Rectangle {
                height: 52px;
                background: Palette.panel-bg;
                border-width: 1px;
                border-color: Palette.border;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    alignment: space-between;
                    cross-axis-alignment: center;

                    HorizontalLayout {
                        spacing: 10px;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: Palette.accent;
                            y: (parent.height - self.height) / 2;
                        }

                        Text {
                            text: "TrangoPlayer";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        background: Palette.segmented-bg;
                        border-radius: 7px;

                        HorizontalLayout {
                            padding: 3px;
                            spacing: 2px;

                            SegmentButton {
                                label: "Normal";
                                active: !root.sentence-mode-active;
                                clicked => {
                                    if (root.sentence-mode-active) {
                                        root.toggle-mode();
                                    }
                                }
                            }

                            SegmentButton {
                                label: "Sentence by sentence";
                                active: root.sentence-mode-active;
                                clicked => {
                                    if (!root.sentence-mode-active) {
                                        root.toggle-mode();
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        GhostButton {
                            label: "Open video…";
                            clicked => { root.open-video-dialog-requested(); }
                        }

                        GhostButton {
                            label: "Open subtitles…";
                            clicked => { root.open-subtitles-dialog-requested(); }
                        }
                    }
                }
            }

            body-row := HorizontalLayout {
                padding: 16px;
                spacing: 16px;

                video-column := VerticalLayout {
                    spacing: 8px;

                    video-frame := Rectangle {
                        // Video frame area, filling the remaining column height.
                        // Transparent while a video is loaded so the mpv underlay
                        // shows through (see `video-loaded` above); otherwise
                        // filled with the window background color as a
                        // placeholder. Its resolved on-screen geometry is
                        // exposed below (`video-frame-x`/-y/-width/-height) so
                        // `video_player.rs` can confine the mpv underlay to
                        // exactly this box instead of the whole window — see
                        // `render_frame`'s doc comment.
                        background: root.video-loaded ? transparent : Palette.window-bg;
                    }

                    ScrubBar {
                        current-time-label: root.current-time-label;
                        duration-label: root.duration-label;
                        progress: root.scrub-progress;
                    }
                }

                VerticalLayout {
                    width: 320px;
                    spacing: 12px;

                    CurrentSentenceCard {
                        vertical-stretch: 0;
                        sentence-label: root.sentence-label;
                        sentence-text: root.sentence-text;
                        has-sentence: root.has-current-sentence;
                        translation-text: root.translation-text;
                        show-translation: root.show-translation;
                        toggle-translation => { root.toggle-translation(); }
                    }

                    SentenceListCard {
                        vertical-stretch: 1;
                        rows: root.sentence-list-rows;
                        current-index: root.sentence-list-current-index;
                        row-clicked(index) => { root.jump-to-cue(index); }
                    }
                }
            }

            if root.sentence-mode-active : HintBar {}
        }

        if root.is-open-video-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Open video file";
            confirm-label: "Open";
            folder-label: root.open-video-folder-label;
            rows: root.open-video-rows;
            selected-index: root.open-video-selected-index;
            row-clicked(index) => { root.select-open-video-row(index); }
            cancel => { root.cancel-open-video-dialog(); }
            confirm => { root.confirm-open-video(); }
        }

        if root.is-open-subtitles-dialog-open : OpenSubtitlesDialog {
            width: parent.width;
            height: parent.height;
            title: root.open-subtitles-title;
            original-linked: root.open-subtitles-original-linked;
            original-name: root.open-subtitles-original-name;
            generation-status: root.subtitle-generation-status;
            generation-error-message: root.subtitle-generation-error-message;
            model-selected: root.whisper-model-selected;
            model-name: root.whisper-model-name;
            translation-linked: root.open-subtitles-translation-linked;
            translation-name: root.open-subtitles-translation-name;
            ollama-model-selected: root.ollama-model-selected;
            ollama-model-name: root.ollama-model-name;
            ollama-target-language: root.ollama-target-language;
            word-analysis-batch-status: root.word-analysis-batch-status;
            word-analysis-batch-progress-current: root.word-analysis-batch-progress-current;
            word-analysis-batch-progress-total: root.word-analysis-batch-progress-total;
            word-analysis-batch-error-message: root.word-analysis-batch-error-message;
            generate-subtitles => { root.generate-subtitles-requested(); }
            select-model => { root.select-whisper-model-requested(); }
            select-ollama-model => { root.select-ollama-model-requested(); }
            set-ollama-target-language(text) => { root.set-ollama-target-language(text); }
            analyze-all-sentences => { root.analyze-all-requested(); }
            link-translation => { root.link-translation-requested(); }
            cancel => { root.cancel-open-subtitles-dialog(); }
            confirm => { root.confirm-open-subtitles-dialog(); }
        }

        // Rendered after OpenSubtitlesDialog so it layers on top when both
        // are open — the translation-link picker is reached from inside
        // the already-open Open Subtitles dialog.
        if root.is-link-translation-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Link translation subtitle";
            confirm-label: "Link";
            folder-label: root.link-translation-folder-label;
            rows: root.link-translation-rows;
            selected-index: root.link-translation-selected-index;
            row-clicked(index) => { root.select-link-translation-row(index); }
            cancel => { root.cancel-link-translation-dialog(); }
            confirm => { root.confirm-link-translation(); }
        }

        // Also reached from inside the Open Subtitles dialog, same as the
        // translation-link picker above.
        if root.is-model-picker-dialog-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Select whisper model";
            confirm-label: "Select";
            folder-label: root.model-picker-folder-label;
            rows: root.model-picker-rows;
            selected-index: root.model-picker-selected-index;
            row-clicked(index) => { root.select-model-picker-row(index); }
            cancel => { root.cancel-model-picker-dialog(); }
            confirm => { root.confirm-model-picker-dialog(); }
        }

        // Also reached from inside the Open Subtitles dialog, same as the
        // whisper model picker above — but lists Ollama models rather than
        // browsing a folder, so folder-label doubles as a loading/error
        // status line instead of a path.
        if root.is-ollama-model-picker-open : FileListDialog {
            width: parent.width;
            height: parent.height;
            title: "Select Ollama model";
            confirm-label: "Select";
            folder-label: root.ollama-model-picker-loading
                ? "Loading models…"
                : (root.ollama-model-picker-error != "" ? root.ollama-model-picker-error : "Installed Ollama models");
            rows: root.ollama-model-picker-rows;
            selected-index: root.ollama-model-picker-selected-index;
            row-clicked(index) => { root.select-ollama-model-picker-row(index); }
            cancel => { root.cancel-ollama-model-picker-dialog(); }
            confirm => { root.confirm-ollama-model-picker-dialog(); }
        }

        // Rendered last so it layers on top of everything else — Ctrl+A
        // can be pressed from the main player screen regardless of which
        // (if any) other dialog happens to be open.
        if root.is-word-analysis-popup-open : WordAnalysisPopup {
            width: parent.width;
            height: parent.height;
            status: root.word-analysis-status;
            rows: root.word-analysis-rows;
            error-message: root.word-analysis-error-message;
            close => { root.close-word-analysis-popup(); }
        }
    }
}
