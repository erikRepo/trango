// TrangoPlayer main window shell.
//
// Top bar in its full visual form per README.md's design tokens (wordmark,
// segmented control, ghost buttons) — pixel reference is
// sketch/design_reference.dc.html#1c. The segmented control's `toggle-mode`
// callback is handled in Rust (crates/app/src/main.rs), which drives
// playback-state::PlayerState::toggle_mode() and mirrors the result back
// into `sentence-mode-active`. Body/bottom-hint-bar content arrives in
// later steps.

import { ListView } from "std-widgets.slint";

/// Color tokens from README.md's "Design Tokens" section, shared across the
/// top bar components below.
global Palette {
    out property <color> window-bg: #1c1d22;
    out property <color> panel-bg: #202127;
    out property <color> border: #3a3c45;
    out property <color> accent: #3b6fd6;
    out property <color> primary-text: #e7e8ec;
    out property <color> muted-text: #8a8d99;
    out property <color> ghost-text: #b4b7c0;
    out property <color> segmented-bg: #2a2c33;
    out property <color> translation-text: #7fa6f0;
    out property <color> modal-bg: #22232a;
    out property <color> chip-muted: #4a4d59;
}

/// One pill in the top bar's Normal / Sentence-by-sentence segmented
/// control; filled with the accent color while `active`, muted otherwise.
component SegmentButton {
    in property <string> label;
    in property <bool> active;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-radius: 5px;
        background: root.active ? Palette.accent : transparent;

        layout := HorizontalLayout {
            padding-left: 16px;
            padding-right: 16px;
            padding-top: 6px;
            padding-bottom: 6px;

            Text {
                text: root.label;
                color: root.active ? white : Palette.muted-text;
                font-family: "Inter";
                font-size: 13px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// Pill-shaped on/off switch used by the current-sentence card's
/// "Translation" toggle: accent-filled track with a white knob when `on`,
/// muted track with the knob on the left otherwise.
component ToggleSwitch {
    in property <bool> on;
    callback toggled;

    width: 34px;
    height: 18px;

    Rectangle {
        border-radius: self.height / 2;
        background: root.on ? Palette.accent : Palette.segmented-bg;
        border-width: 1px;
        border-color: Palette.border;

        Rectangle {
            width: 14px;
            height: 14px;
            border-radius: self.height / 2;
            background: white;
            y: (parent.height - self.height) / 2;
            x: root.on ? parent.width - self.width - 2px : 2px;

            animate x { duration: 120ms; easing: ease-out; }
        }

        TouchArea {
            clicked => { root.toggled(); }
        }
    }
}

/// A bordered, no-fill "Open video…" / "Open subtitles…" top bar button.
/// "Open video…" is wired to the Open Video dialog (Vaihe 18, see
/// `OpenVideoDialog` below); "Open subtitles…" stays static until Vaihe 19.
component GhostButton {
    in property <string> label;
    callback clicked;

    min-width: layout.min-width;
    min-height: layout.min-height;

    Rectangle {
        border-width: 1px;
        border-radius: 6px;
        border-color: Palette.border;

        layout := HorizontalLayout {
            padding-left: 14px;
            padding-right: 14px;
            padding-top: 7px;
            padding-bottom: 7px;

            Text {
                text: root.label;
                color: Palette.ghost-text;
                font-family: "JetBrains Mono";
                font-size: 12px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }

        TouchArea {
            clicked => { root.clicked(); }
        }
    }
}

/// The right-hand sentence panel's top card: "Sentence N / M" (uppercase,
/// mono, muted) left / "Translation" label + toggle switch right, above the
/// current cue's original-language text, a divider, and (while
/// `show-translation` is on) the translation text in accent-tinted blue.
/// `sentence-label`/`sentence-text`/`has-sentence`/`translation-text` are
/// set from Rust: `main.rs` after loading a subtitle file, and
/// `video_player.rs`'s scrub bar poll (while in `SentenceBySentence` mode,
/// synced from mpv's `time-pos`) — see `crates/app/src/sentence_card.rs`.
/// `show-translation` is wired directly to `main.rs`'s `toggle-translation`
/// callback (see `wire_player_state`), independent of cue changes. The
/// sentence-list card underneath it arrives in a later TODO.md step.
component CurrentSentenceCard {
    in property <string> sentence-label;
    in property <string> sentence-text;
    in property <bool> has-sentence;
    in property <string> translation-text;
    in property <bool> show-translation;
    callback toggle-translation;

    Rectangle {
        border-width: 1px;
        border-radius: 8px;
        border-color: Palette.border;
        background: Palette.panel-bg;

        VerticalLayout {
            padding: 20px;
            spacing: 12px;

            HorizontalLayout {
                alignment: space-between;
                cross-axis-alignment: center;

                Text {
                    text: root.sentence-label;
                    color: Palette.muted-text;
                    font-family: "JetBrains Mono";
                    font-size: 10px;
                    font-weight: 600;
                }

                HorizontalLayout {
                    spacing: 8px;
                    cross-axis-alignment: center;

                    Text {
                        text: "Translation";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 12px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }

                    ToggleSwitch {
                        on: root.show-translation;
                        toggled => { root.toggle-translation(); }
                    }
                }
            }

            Text {
                text: root.sentence-text;
                color: root.has-sentence ? Palette.primary-text : Palette.muted-text;
                font-family: "Inter";
                font-size: 24px;
                font-weight: 600;
                wrap: word-wrap;
            }

            Rectangle {
                height: 1px;
                background: Palette.border;
            }

            if root.show-translation : Text {
                text: root.translation-text;
                color: Palette.translation-text;
                font-family: "Inter";
                font-size: 18px;
                font-weight: 500;
                wrap: word-wrap;
            }
        }
    }
}

/// One row in the sentence list: `"index · text"`, plus whether it's the
/// currently focused cue (highlighted with an accent-tinted pill).
struct SentenceListRow {
    label: string,
    is-current: bool,
}

/// The right-hand sentence panel's scrollable "all cues" list, underneath
/// `CurrentSentenceCard`. `rows`/`current-index` are set from Rust
/// (`crates/app/src/sentence_list.rs`) whenever the loaded cues or the
/// current cue change. Clicking a row emits `row-clicked` with that row's
/// index, which `main.rs` wires to the same `playback-state::jump_to_cue`
/// navigation used by arrow-key navigation — see README's "Sentence list"
/// interaction spec.
component SentenceListCard inherits Rectangle {
    in property <[SentenceListRow]> rows: [];
    in property <int> current-index: -1;
    callback row-clicked(int);

    /// Fixed row height, matched by `row-y`/`bring-into-view` below so the
    /// scroll-into-view math doesn't need to measure text layout.
    property <length> row-height: 32px;

    border-width: 1px;
    border-radius: 8px;
    border-color: Palette.border;
    background: Palette.panel-bg;

    VerticalLayout {
        padding: 12px;
        spacing: 4px;

        Text {
            text: "Sentence list";
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 10px;
            font-weight: 600;
        }

        list := ListView {
            for row[index] in root.rows : Rectangle {
                height: root.row-height;
                border-radius: 6px;
                background: row.is-current ? Palette.accent.with-alpha(0.22) : transparent;

                Text {
                    text: row.label;
                    color: row.is-current ? Palette.primary-text : Palette.muted-text;
                    font-family: "Inter";
                    font-size: 13px;
                    font-weight: 500;
                    overflow: elide;
                    x: 10px;
                    width: parent.width - 20px;
                    vertical-alignment: center;
                }

                TouchArea {
                    clicked => { root.row-clicked(index); }
                }
            }
        }
    }

    /// The current row's y position within `list`'s scrolled viewport —
    /// negative/beyond `visible-height` means it's currently out of view.
    pure function row-y(index: int) -> length {
        return list.viewport-y + index * root.row-height;
    }

    /// Scrolls `list` just enough to bring row `index` fully into view,
    /// without otherwise disturbing the current scroll position.
    function bring-into-view(index: int) {
        if (row-y(index) < 0) {
            list.viewport-y += 0 - row-y(index);
        }
        if (row-y(index) + root.row-height > list.visible-height) {
            list.viewport-y -= row-y(index) + root.row-height - list.visible-height;
        }
    }

    changed current-index => {
        if (root.current-index < 0 || root.current-index >= root.rows.length) {
            return;
        }
        root.bring-into-view(root.current-index);
    }
}

/// One row in the Open Video dialog's listing: either a navigable row (the
/// "‥ Up" row or a subfolder — `is-navigable`, no `size-label`, never
/// `is-selected`; clicking it navigates the dialog to a different folder)
/// or a selectable video file (`is-selected` driving the accent-tinted
/// background/chip color). Set from Rust in
/// `crates/app/src/open_video_dialog.rs`.
struct OpenVideoRow {
    name: string,
    size-label: string,
    is-selected: bool,
    is-navigable: bool,
}

/// The Open Video dialog (`TODO.md` Vaihe 18): a modal overlay listing a
/// folder's video files and subfolders — pixel reference
/// `sketch/design_reference.dc.html#2a`, left mock (extended here with
/// in-dialog folder navigation, not shown in that static mock) — no
/// OS-native file/folder picker, an in-app list instead.
/// `folder-label`/`rows`/`selected-index` are set from Rust
/// (`crates/app/src/open_video_dialog.rs`) when the top bar's "Open
/// video…" button is clicked, and again whenever a navigable row changes
/// the listed folder. Clicking a row emits `row-clicked` with its index —
/// `main.rs` decides whether that navigates (an `Up`/`Folder` row) or
/// selects (a video row); the backdrop, header "✕", and footer "Cancel"
/// all emit `cancel`; footer "Open" emits `confirm` (a no-op while nothing
/// is selected) — `main.rs`'s `wire_open_video_dialog` wires all three to
/// `AppWindow`'s matching callbacks, `confirm` also loading the selected
/// file.
component OpenVideoDialog {
    in property <string> folder-label;
    in property <[OpenVideoRow]> rows: [];
    in property <int> selected-index: -1;
    callback row-clicked(int);
    callback cancel();
    callback confirm();

    Rectangle {
        background: rgba(0, 0, 0, 0.55);

        TouchArea {
            // Clicking the dimmed backdrop cancels, same as the header's
            // close button and footer's Cancel button.
            clicked => { root.cancel(); }
        }

        Rectangle {
            width: 640px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Palette.modal-bg;
            border-width: 1px;
            border-radius: 12px;
            border-color: Palette.border;
            drop-shadow-color: rgba(0, 0, 0, 0.6);
            drop-shadow-blur: 40px;
            drop-shadow-offset-y: 16px;
            clip: true;

            TouchArea {
                // Swallows clicks inside the card so they don't fall
                // through to the backdrop's cancel handler above.
            }

            VerticalLayout {
                Rectangle {
                    height: 52px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: space-between;
                        cross-axis-alignment: center;

                        Text {
                            text: "Open video file";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        TouchArea {
                            width: 20px;
                            height: 20px;
                            clicked => { root.cancel(); }

                            Text {
                                text: "✕";
                                color: Palette.muted-text;
                                font-family: "Inter";
                                font-size: 16px;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                VerticalLayout {
                    vertical-stretch: 1;
                    padding: 16px;
                    spacing: 6px;

                    Text {
                        text: root.folder-label;
                        color: Palette.muted-text;
                        font-family: "JetBrains Mono";
                        font-size: 10px;
                        font-weight: 600;
                        letter-spacing: 0.8px;
                    }

                    if root.rows.length == 0 : Text {
                        text: "This folder is empty.";
                        color: Palette.muted-text;
                        font-family: "Inter";
                        font-size: 13px;
                    }

                    ListView {
                        for row[index] in root.rows : Rectangle {
                            height: 44px;
                            border-radius: 7px;
                            background: row.is-selected ? Palette.accent.with-alpha(0.22) : transparent;

                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 12px;
                                spacing: 10px;
                                cross-axis-alignment: center;

                                if !row.is-navigable : Rectangle {
                                    width: 28px;
                                    height: 20px;
                                    border-radius: 3px;
                                    background: row.is-selected ? Palette.accent : Palette.chip-muted;
                                }

                                VerticalLayout {
                                    alignment: center;

                                    Text {
                                        text: row.name;
                                        color: row.is-selected ? Palette.primary-text : Palette.ghost-text;
                                        font-family: "Inter";
                                        font-size: 13px;
                                        font-weight: row.is-navigable ? 600 : 500;
                                        overflow: elide;
                                    }

                                    if row.size-label != "" : Text {
                                        text: row.size-label;
                                        color: Palette.muted-text;
                                        font-family: "JetBrains Mono";
                                        font-size: 11px;
                                    }
                                }
                            }

                            TouchArea {
                                clicked => { root.row-clicked(index); }
                            }
                        }
                    }
                }

                Rectangle {
                    height: 60px;
                    border-width: 1px;
                    border-color: Palette.border;

                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        alignment: end;
                        spacing: 10px;
                        cross-axis-alignment: center;

                        Rectangle {
                            border-width: 1px;
                            border-radius: 6px;
                            border-color: Palette.border;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Cancel";
                                    color: Palette.ghost-text;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => { root.cancel(); }
                            }
                        }

                        Rectangle {
                            border-radius: 6px;
                            background: Palette.accent;
                            opacity: root.selected-index >= 0 ? 1.0 : 0.5;

                            HorizontalLayout {
                                padding-left: 16px;
                                padding-right: 16px;
                                padding-top: 8px;
                                padding-bottom: 8px;

                                Text {
                                    text: "Open";
                                    color: white;
                                    font-family: "Inter";
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                }
                            }

                            TouchArea {
                                clicked => {
                                    if (root.selected-index >= 0) {
                                        root.confirm();
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

/// Bottom hint bar shown only in `SentenceBySentence` mode (see the `if`
/// guard where it's instantiated in `AppWindow`), listing the Right/Left/
/// Space keyboard shortcuts plus Ctrl+T. Right/Left/Space are handled by
/// `AppWindow`'s `key-pressed` callback and drive
/// `next-cue`/`previous-cue`/`repeat-cue`, wired to `playback-state`
/// navigation and mpv seeking in `crates/app/src/main.rs` and
/// `video_player.rs`. Ctrl+T calls `toggle-translation` directly — it also
/// works outside `SentenceBySentence` mode (translation visibility is
/// purely visual, per README), it's just only *advertised* here since this
/// is the app's only hint surface so far.
component HintBar {
    height: 34px;

    Rectangle {
        background: Palette.window-bg;
        border-width: 1px;
        border-color: Palette.border;

        HorizontalLayout {
            alignment: center;
            spacing: 24px;

            Text {
                text: "← previous sentence";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                text: "space · repeat sentence";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                text: "→ next sentence";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }

            Text {
                text: "ctrl+t · toggle translation";
                color: Palette.muted-text;
                font-family: "JetBrains Mono";
                font-size: 11px;
                font-weight: 500;
                vertical-alignment: center;
            }
        }
    }
}

/// Time / progress control below the video frame: current time (mono,
/// muted) — 4px track with accent-filled progress and a white circular
/// thumb — total time (mono, muted). `current-time-label`/`duration-label`
/// and `progress` (0.0–1.0) are set from Rust, which polls mpv's
/// `time-pos`/`duration` properties (see `video_player.rs`).
component ScrubBar {
    in property <string> current-time-label;
    in property <string> duration-label;
    in property <float> progress: 0.0;

    height: 32px;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        spacing: 10px;
        cross-axis-alignment: center;

        Text {
            text: root.current-time-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }

        track := Rectangle {
            height: 4px;
            border-radius: 2px;
            background: Palette.border;

            Rectangle {
                x: 0px;
                width: parent.width * root.progress;
                height: parent.height;
                border-radius: 2px;
                background: Palette.accent;
            }

            Rectangle {
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: white;
                x: parent.width * root.progress - self.width / 2;
                y: (parent.height - self.height) / 2;
            }
        }

        Text {
            text: root.duration-label;
            color: Palette.muted-text;
            font-family: "JetBrains Mono";
            font-size: 11px;
            font-weight: 500;
            vertical-alignment: center;
        }
    }
}

export component AppWindow inherits Window {
    in property <string> version;
    in property <bool> sentence-mode-active: false;
    // Whether crates/app/src/video_player.rs has an mpv OpenGL render
    // context underlay active. While true, the video area below is left
    // fully transparent so that underlay (drawn straight into the window's
    // backbuffer before this scene, via Window::set_rendering_notifier) is
    // visible through it; opaque window-bg is only needed as a placeholder
    // when no video is loaded yet.
    in property <bool> video-loaded: false;
    // Scrub bar state, polled from mpv's `time-pos`/`duration` properties in
    // video_player.rs and formatted via playback_state::format_time.
    in property <string> current-time-label: "00:00";
    in property <string> duration-label: "00:00";
    in property <float> scrub-progress: 0.0;
    // Current-sentence card state, mirrored from playback_state::PlayerState
    // by crates/app/src/sentence_card.rs — see CurrentSentenceCard above.
    in property <string> sentence-label: "Sentence – / –";
    in property <string> sentence-text: "No sentence loaded.";
    in property <bool> has-current-sentence: false;
    in property <string> translation-text: "";
    // Whether the current-sentence card's translation line is shown,
    // mirrored from playback_state::PlayerState.show_translation by
    // main.rs's wire_player_state — flipped by the toggle-translation
    // callback below, off by default.
    in property <bool> show-translation: false;
    // Sentence list state, mirrored from playback_state::PlayerState by
    // crates/app/src/sentence_list.rs — see SentenceListCard above.
    in property <[SentenceListRow]> sentence-list-rows: [];
    in property <int> sentence-list-current-index: -1;
    callback toggle-mode();
    // Invoked by the current-sentence card's Translation toggle switch —
    // wired in main.rs's wire_player_state to
    // playback_state::PlayerState::toggle_translation().
    callback toggle-translation();
    // Sentence-by-sentence navigation, invoked by `nav-focus`'s key-pressed
    // handler below for Right/Left/Space respectively — see
    // `crates/app/src/main.rs` for how they drive `playback-state` and mpv.
    callback next-cue();
    callback previous-cue();
    callback repeat-cue();
    // Sentence list row click, invoked by SentenceListCard with the clicked
    // row's index — wired in main.rs to playback_state::jump_to_cue, the
    // same navigation call arrow keys drive.
    callback jump-to-cue(int);
    // Open Video dialog state (TODO.md Vaihe 18), set from Rust by
    // crates/app/src/open_video_dialog.rs — see OpenVideoDialog above.
    in property <bool> is-open-video-dialog-open: false;
    in property <string> open-video-folder-label: "";
    in property <[OpenVideoRow]> open-video-rows: [];
    in property <int> open-video-selected-index: -1;
    // Invoked by the top bar's "Open video…" GhostButton; wired in main.rs's
    // wire_open_video_dialog to list the default folder's video files and
    // open the dialog.
    callback open-video-dialog-requested();
    // Invoked by the dialog's backdrop click / "✕" / "Cancel" — closes it.
    callback cancel-open-video-dialog();
    // Invoked by a dialog row click, with that row's index — marks it
    // selected.
    callback select-open-video-row(int);
    // Invoked by the dialog's "Open" button — loads the selected file.
    callback confirm-open-video();

    title: "TrangoPlayer v" + version;
    width: 960px;
    // 660px (was 600px pre-Vaihe-17): CurrentSentenceCard's header row grew
    // a "Translation" label + toggle switch, and — while show-translation
    // is on — an extra wrapped translation line below the divider. Without
    // the extra headroom the fixed-height window has no slack left for the
    // bottom HintBar once the sentence panel's natural content height grows,
    // so it gets clipped off below the window's visible bounds.
    height: 660px;
    forward-focus: nav-focus;

    nav-focus := FocusScope {
        key-pressed(event) => {
            if (event.modifiers.control && (event.text == "t" || event.text == "T")) {
                // Translation visibility is purely visual and independent
                // of playback mode (see README), so Ctrl+T is handled
                // before the sentence-mode-active guard below, unlike
                // Right/Left/Space which only make sense in
                // SentenceBySentence mode.
                root.toggle-translation();
                accept
            } else if (!root.sentence-mode-active) {
                reject
            } else if (event.text == Key.RightArrow) {
                root.next-cue();
                accept
            } else if (event.text == Key.LeftArrow) {
                root.previous-cue();
                accept
            } else if (event.text == " ") {
                root.repeat-cue();
                accept
            } else {
                reject
            }
        }

        VerticalLayout {
            Rectangle {
                height: 52px;
                background: Palette.panel-bg;
                border-width: 1px;
                border-color: Palette.border;

                HorizontalLayout {
                    padding-left: 16px;
                    padding-right: 16px;
                    alignment: space-between;
                    cross-axis-alignment: center;

                    HorizontalLayout {
                        spacing: 10px;

                        Rectangle {
                            width: 8px;
                            height: 8px;
                            border-radius: 4px;
                            background: Palette.accent;
                            y: (parent.height - self.height) / 2;
                        }

                        Text {
                            text: "TrangoPlayer";
                            color: Palette.primary-text;
                            font-family: "Inter";
                            font-size: 14px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        background: Palette.segmented-bg;
                        border-radius: 7px;

                        HorizontalLayout {
                            padding: 3px;
                            spacing: 2px;

                            SegmentButton {
                                label: "Normal";
                                active: !root.sentence-mode-active;
                                clicked => {
                                    if (root.sentence-mode-active) {
                                        root.toggle-mode();
                                    }
                                }
                            }

                            SegmentButton {
                                label: "Sentence by sentence";
                                active: root.sentence-mode-active;
                                clicked => {
                                    if (!root.sentence-mode-active) {
                                        root.toggle-mode();
                                    }
                                }
                            }
                        }
                    }

                    HorizontalLayout {
                        spacing: 8px;

                        GhostButton {
                            label: "Open video…";
                            clicked => { root.open-video-dialog-requested(); }
                        }

                        GhostButton {
                            label: "Open subtitles…";
                        }
                    }
                }
            }

            HorizontalLayout {
                padding: 16px;
                spacing: 16px;

                VerticalLayout {
                    spacing: 8px;

                    Rectangle {
                        // Video frame area, filling the remaining column height.
                        // Transparent while a video is loaded so the mpv underlay
                        // shows through (see `video-loaded` above); otherwise
                        // filled with the window background color as a
                        // placeholder. Precise rounded corners land in a later
                        // TODO.md step.
                        background: root.video-loaded ? transparent : Palette.window-bg;
                    }

                    ScrubBar {
                        current-time-label: root.current-time-label;
                        duration-label: root.duration-label;
                        progress: root.scrub-progress;
                    }
                }

                VerticalLayout {
                    width: 320px;
                    spacing: 12px;

                    CurrentSentenceCard {
                        vertical-stretch: 0;
                        sentence-label: root.sentence-label;
                        sentence-text: root.sentence-text;
                        has-sentence: root.has-current-sentence;
                        translation-text: root.translation-text;
                        show-translation: root.show-translation;
                        toggle-translation => { root.toggle-translation(); }
                    }

                    SentenceListCard {
                        vertical-stretch: 1;
                        rows: root.sentence-list-rows;
                        current-index: root.sentence-list-current-index;
                        row-clicked(index) => { root.jump-to-cue(index); }
                    }
                }
            }

            if root.sentence-mode-active : HintBar {}
        }

        if root.is-open-video-dialog-open : OpenVideoDialog {
            width: parent.width;
            height: parent.height;
            folder-label: root.open-video-folder-label;
            rows: root.open-video-rows;
            selected-index: root.open-video-selected-index;
            row-clicked(index) => { root.select-open-video-row(index); }
            cancel => { root.cancel-open-video-dialog(); }
            confirm => { root.confirm-open-video(); }
        }
    }
}
